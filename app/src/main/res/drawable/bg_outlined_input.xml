<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_focused="true">
        <shape android:shape="rectangle">
            <solid android:color="@color/color_bg_white" />
            <corners android:radius="@dimen/radius_input" />
            <stroke android:width="2dp" android:color="@color/color_accent_blue" />
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <solid android:color="@color/color_bg_white" />
            <corners android:radius="@dimen/radius_input" />
            <stroke android:width="1dp" android:color="@color/color_divider" />
        </shape>
    </item>
</selector>
