<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Base Theme (Light Mode) -->
    <style name="Theme.Numo" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <!-- Primary brand color. -->
        <item name="colorPrimary">@color/color_primary_green_light</item>
        <item name="colorPrimaryVariant">@color/color_primary_green</item>
        <item name="colorOnPrimary">@color/color_bg_white</item>
        <!-- Secondary brand color. -->
        <item name="colorSecondary">@color/color_primary_green_light</item>
        <item name="colorSecondaryVariant">@color/color_primary_green</item>
        <item name="colorOnSecondary">@color/color_bg_white</item>
        <!-- Status bar color - matches window background for seamless edge-to-edge -->
        <item name="android:statusBarColor">@color/color_bg_white</item>
        <item name="android:windowLightStatusBar">true</item>
        <!-- Navigation bar: solid white so it follows the light theme
             everywhere except the POS screen (which overrides it to use
             the per-theme background color). -->
        <item name="android:navigationBarColor">@color/color_bg_white</item>
        <item name="android:windowLightNavigationBar">true</item>
        <!-- Text colors -->
        <item name="android:textColor">@color/color_text_primary</item>
        <!-- Background colors -->
        <item name="android:windowBackground">@color/color_bg_white</item>
        <item name="android:colorBackground">@color/color_bg_white</item>
        <!-- Surface colors -->
        <item name="colorSurface">@color/color_bg_white</item>
        <item name="colorOnSurface">@color/color_text_primary</item>
        <!-- Normalize MaterialButton height across all variants -->
        <item name="materialButtonStyle">@style/Widget.Numo.Button</item>
        <!-- Icon tint -->
        <item name="colorControlNormal">@color/color_text_secondary</item>
        <!-- Switch/toggle active color -->
        <item name="colorControlActivated">@color/color_success_green</item>
        <!-- Popup menu styling -->
        <item name="popupMenuStyle">@style/Widget.Numo.PopupMenu</item>
        <item name="android:popupMenuStyle">@style/Widget.Numo.PopupMenu</item>
        <!-- Snackbar styling -->
        <item name="snackbarStyle">@style/Widget.Numo.Snackbar</item>
        <item name="snackbarTextViewStyle">@style/Widget.Numo.Snackbar.Text</item>
    </style>

    <!-- Popup Menu Style -->
    <style name="Widget.Numo.PopupMenu" parent="Widget.MaterialComponents.PopupMenu">
        <item name="android:popupBackground">@drawable/bg_popup_menu</item>
        <item name="android:popupElevation">0dp</item>
    </style>
    
    <!-- Splash Screen Theme for Android 12+ -->
    <style name="Theme.Numo.Splash" parent="Theme.Numo">
        <!-- Splash screen background: Navy -->
        <item name="android:windowBackground">@color/numo_navy</item>
        <item name="android:statusBarColor">@color/numo_navy</item>
        <item name="android:navigationBarColor">@color/numo_navy</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:windowLightNavigationBar">false</item>
    </style>

    <!-- Variant Styles (not duplicated in styles.xml) -->
    
    <style name="Text.DisplayAmount.Green">
        <item name="android:textColor">@color/color_primary_green_light</item>
    </style>

    <!-- Legacy Toolbar Style -->
    <style name="Widget.App.Toolbar.Light" parent="Widget.MaterialComponents.Toolbar.Primary">
        <item name="android:background">@color/color_bg_white</item>
        <item name="titleTextColor">@color/color_text_primary</item>
        <item name="subtitleTextColor">@color/color_text_secondary</item>
        <item name="colorControlNormal">@color/color_text_primary</item>
    </style>
    
    <!-- Fullscreen Theme for Barcode Scanner -->
    <style name="Theme.Numo.Fullscreen" parent="Theme.Numo">
        <item name="android:windowFullscreen">true</item>
        <item name="android:windowContentOverlay">@null</item>
        <item name="android:statusBarColor">@color/color_bg_scanner</item>
        <item name="android:navigationBarColor">@color/color_bg_scanner</item>
        <item name="android:windowLightStatusBar">false</item>
    </style>

    <!-- Google-style Centered Dialog Theme -->
    <style name="Theme.Numo.Dialog" parent="Theme.MaterialComponents.Light.Dialog">
        <item name="android:windowBackground">@android:color/transparent</item>
        <item name="android:backgroundDimEnabled">true</item>
        <item name="android:backgroundDimAmount">0.5</item>
        <item name="android:windowNoTitle">true</item>
        <item name="android:windowIsFloating">true</item>
        <item name="android:windowSoftInputMode">adjustResize</item>
        <item name="android:windowAnimationStyle">@style/Animation.AppCompat.Dialog</item>
    </style>

    <!-- Bottom Sheet Animation -->
    <style name="Animation.Numo.BottomSheet" parent="Animation.AppCompat.Dialog">
        <item name="android:windowEnterAnimation">@anim/slide_up</item>
        <item name="android:windowExitAnimation">@anim/slide_down</item>
    </style>
    
    <!-- Bottom Sheet Fragment Theme (DayNight-aware) -->
    <style name="Theme.Numo.BottomSheet" parent="Theme.MaterialComponents.DayNight.BottomSheetDialog">
        <item name="android:windowBackground">@android:color/transparent</item>
        <item name="android:backgroundDimEnabled">true</item>
        <item name="android:backgroundDimAmount">0.5</item>
        <item name="android:windowNoTitle">true</item>
        <item name="android:windowIsFloating">false</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
        <item name="android:windowLightNavigationBar">true</item>
        <item name="enableEdgeToEdge">true</item>
        <item name="bottomSheetStyle">@style/Widget.Numo.BottomSheet</item>
        <item name="android:windowSoftInputMode">adjustResize</item>
    </style>

    <!-- Bottom Sheet Widget Style -->
    <style name="Widget.Numo.BottomSheet" parent="Widget.MaterialComponents.BottomSheet.Modal">
        <item name="backgroundTint">@color/color_bg_white</item>
        <item name="shapeAppearance">@style/ShapeAppearance.Numo.BottomSheet</item>
        <item name="behavior_peekHeight">auto</item>
        <item name="behavior_fitToContents">true</item>
        <item name="android:elevation">16dp</item>
    </style>
    
    <!-- Bottom Sheet Shape -->
    <style name="ShapeAppearance.Numo.BottomSheet" parent="ShapeAppearance.MaterialComponents.LargeComponent">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSizeTopLeft">20dp</item>
        <item name="cornerSizeTopRight">20dp</item>
        <item name="cornerSizeBottomLeft">0dp</item>
        <item name="cornerSizeBottomRight">0dp</item>
    </style>
</resources>
