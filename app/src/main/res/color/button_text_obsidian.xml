<?xml version="1.0" encoding="utf-8"?>
<!--
    Text color for the POS submit button when the Obsidian theme is active.
    Background (bg_button_white) auto-inverts between light and night modes,
    so we use color_text_primary — a theme-aware token that matches.
-->
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_enabled="false" android:color="#4DFFFFFF" />
    <item android:color="@color/color_text_primary" />
</selector>
