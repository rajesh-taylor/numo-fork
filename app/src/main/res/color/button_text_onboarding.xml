<?xml version="1.0" encoding="utf-8"?>
<!--
    Text color for onboarding primary buttons (white fill on dark hero backdrop).
    Light mode: dark navy text on white fill.
    Night variant in res/color-night/ inverts to white text on dark-gray fill
    (bg_button_white auto-inverts in night mode).
-->
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_enabled="false" android:color="#4DFFFFFF" />
    <item android:color="@color/numo_navy" />
</selector>
