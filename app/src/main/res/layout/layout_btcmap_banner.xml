<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/btcmap_banner_container"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_gravity="top|center_horizontal"
    android:paddingHorizontal="16dp"
    android:paddingTop="16dp"
    android:visibility="gone">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_btcmap_banner"
        android:padding="16dp"
        android:alpha="0.9"> <!-- 90% opacity for slight transparency -->

        <ImageView
            android:id="@+id/banner_logo"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/ic_btcmap_logo"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent" />

        <TextView
            android:id="@+id/banner_title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="BTCMap"
            android:textStyle="bold"
            android:textColor="@android:color/black"
            android:layout_marginStart="12dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toEndOf="@id/banner_logo"
            app:layout_constraintEnd_toEndOf="parent" />

        <TextView
            android:id="@+id/banner_message"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="@string/btcmap_banner_message"
            android:textColor="@android:color/black"
            android:layout_marginTop="4dp"
            android:layout_marginStart="12dp"
            app:layout_constraintTop_toBottomOf="@id/banner_title"
            app:layout_constraintStart_toEndOf="@id/banner_logo"
            app:layout_constraintEnd_toEndOf="parent" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:orientation="horizontal"
            android:gravity="center"
            android:weightSum="2"
            app:layout_constraintTop_toBottomOf="@id/banner_logo"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <Button
                android:id="@+id/btn_dismiss"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_weight="1"
                android:text="@string/btcmap_banner_dismiss"
                android:minWidth="0dp"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                style="?attr/materialButtonOutlinedStyle"
                android:textSize="13sp"
                app:autoSizeTextType="uniform"
                app:autoSizeMinTextSize="10sp"
                app:autoSizeMaxTextSize="14sp"
                android:maxLines="1"
                android:textColor="@android:color/black"
                android:layout_marginEnd="4dp" />

            <Button
                android:id="@+id/btn_learn_more"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_weight="1"
                android:text="@string/btcmap_promo_learn_more"
                android:minWidth="0dp"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                android:textSize="13sp"
                app:autoSizeTextType="uniform"
                app:autoSizeMinTextSize="10sp"
                app:autoSizeMaxTextSize="14sp"
                android:maxLines="1"
                android:backgroundTint="@android:color/black"
                android:textColor="@android:color/white"
                android:layout_marginStart="4dp" />
        </LinearLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>

</FrameLayout>
