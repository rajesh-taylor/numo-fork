<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/color_bg_white">

    <!-- Top Bar -->
    <com.electricdreams.numo.ui.components.NumoTopBar
        android:id="@+id/top_bar"
        android:layout_width="match_parent"
        android:layout_height="@dimen/top_bar_height"
        app:topBarTitle="@string/basket_names_settings_title"
        app:layout_constraintTop_toTopOf="parent" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:fillViewport="true"
        app:layout_constraintTop_toBottomOf="@id/top_bar"
        app:layout_constraintBottom_toBottomOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="@dimen/space_2xl">

            <!-- Hero Section -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingHorizontal="@dimen/margin_screen_horizontal"
                android:paddingTop="@dimen/margin_screen_horizontal"
                android:paddingBottom="@dimen/margin_screen_horizontal">

                <!-- Description -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/basket_names_settings_description"
                    android:textAppearance="@style/Text.RowSubtitle"
                    android:lineSpacingMultiplier="1.3" />

            </LinearLayout>

            <!-- Names List Container -->
            <LinearLayout
                android:id="@+id/names_container"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <!-- Section Header -->
                <TextView
                    android:id="@+id/names_header"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:paddingHorizontal="@dimen/margin_screen_horizontal"
                    android:paddingTop="@dimen/section_gap"
                    android:paddingBottom="@dimen/row_padding_vertical"
                    android:text="@string/basket_names_settings_presets_header"
                    android:textAppearance="@style/Text.SectionHeader"
                    android:visibility="gone"
                    tools:visibility="visible" />

                <!-- Names List -->
                <LinearLayout
                    android:id="@+id/names_card"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:visibility="gone"
                    tools:visibility="visible">

                    <LinearLayout
                        android:id="@+id/names_list"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical" />

                </LinearLayout>

                <!-- Empty State -->
                <include
                    android:id="@+id/empty_state"
                    layout="@layout/component_empty_state" />

            </LinearLayout>

            <!-- Add Name Button -->
            <Button
                android:id="@+id/add_name_button"
                style="@style/Widget.Button.Secondary.Outlined"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_m"
                android:layout_marginHorizontal="@dimen/margin_screen_horizontal"
                android:text="@string/basket_names_settings_add_name"
                android:drawableStart="@drawable/ic_add"
                android:drawablePadding="@dimen/space_s" />

            <!-- Example suggestions -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_xl"
                android:paddingHorizontal="@dimen/margin_screen_horizontal"
                android:text="@string/basket_names_settings_examples"
                android:textAppearance="@style/Text.Caption"
                android:lineSpacingMultiplier="1.4" />

            <!-- Clear All Button (only shown when items exist) -->
            <LinearLayout
                android:id="@+id/clear_all_button"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginTop="@dimen/space_2xl"
                android:orientation="horizontal"
                android:gravity="center"
                android:clickable="true"
                android:focusable="true"
                android:background="?attr/selectableItemBackground"
                android:visibility="gone"
                tools:visibility="visible">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/basket_names_settings_clear_all"
                    android:textAppearance="@style/Text.Link"
                    android:textColor="@color/color_warning_red" />
            </LinearLayout>

        </LinearLayout>
    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>
