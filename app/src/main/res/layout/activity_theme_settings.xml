<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/color_bg_white">

    <!-- Top App Bar -->
    <com.electricdreams.numo.ui.components.NumoTopBar
        android:id="@+id/top_bar"
        android:layout_width="match_parent"
        android:layout_height="@dimen/top_bar_height"
        app:topBarTitle="@string/settings_theme_title"
        app:layout_constraintTop_toTopOf="parent" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@id/top_bar">

        <LinearLayout
            android:id="@+id/theme_content"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="@dimen/space_2xl">

            <!-- Mode Section Header -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingHorizontal="@dimen/margin_screen_horizontal"
                android:paddingTop="@dimen/space_l"
                android:paddingBottom="@dimen/row_padding_vertical"
                android:text="@string/theme_settings_section_mode"
                android:textAppearance="@style/Text.SectionHeader" />

            <!-- Dark Mode Toggle -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingVertical="@dimen/row_padding_vertical"
                android:paddingHorizontal="@dimen/margin_screen_horizontal"
                android:background="@drawable/bg_row_ripple">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/theme_settings_dark_mode_label"
                    android:textAppearance="@style/Text.RowTitle" />

                <androidx.appcompat.widget.SwitchCompat
                    android:id="@+id/dark_mode_switch"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    app:thumbTint="@color/selector_switch_thumb"
                    app:trackTint="@color/selector_switch_track" />
            </LinearLayout>

            <!-- App Theme Section Header -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingHorizontal="@dimen/margin_screen_horizontal"
                android:paddingTop="@dimen/section_gap"
                android:paddingBottom="@dimen/row_padding_vertical"
                android:text="@string/theme_settings_section_app_theme"
                android:textAppearance="@style/Text.SectionHeader" />

            <!-- Theme Radio Group -->
            <RadioGroup
                android:id="@+id/theme_radio_group"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <RadioButton
                    android:id="@+id/radio_obsidian"
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/settings_item_height"
                    android:background="?attr/selectableItemBackground"
                    android:button="@null"
                    android:drawableEnd="@drawable/selector_radio_custom"
                    android:gravity="center_vertical"
                    android:paddingHorizontal="@dimen/margin_screen_horizontal"
                    android:text="@string/theme_settings_option_obsidian"
                    android:textAppearance="@style/Text.RowTitle" />

                <RadioButton
                    android:id="@+id/radio_bitcoin_orange"
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/settings_item_height"
                    android:background="?attr/selectableItemBackground"
                    android:button="@null"
                    android:drawableEnd="@drawable/selector_radio_custom"
                    android:gravity="center_vertical"
                    android:paddingHorizontal="@dimen/margin_screen_horizontal"
                    android:text="@string/theme_settings_option_bitcoin_orange"
                    android:textAppearance="@style/Text.RowTitle" />

                <RadioButton
                    android:id="@+id/radio_green"
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/settings_item_height"
                    android:background="?attr/selectableItemBackground"
                    android:button="@null"
                    android:drawableEnd="@drawable/selector_radio_custom"
                    android:gravity="center_vertical"
                    android:paddingHorizontal="@dimen/margin_screen_horizontal"
                    android:text="@string/theme_settings_option_green"
                    android:textAppearance="@style/Text.RowTitle" />

                <RadioButton
                    android:id="@+id/radio_white"
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/settings_item_height"
                    android:background="?attr/selectableItemBackground"
                    android:button="@null"
                    android:drawableEnd="@drawable/selector_radio_custom"
                    android:gravity="center_vertical"
                    android:paddingHorizontal="@dimen/margin_screen_horizontal"
                    android:text="@string/theme_settings_option_white"
                    android:textAppearance="@style/Text.RowTitle" />
            </RadioGroup>

        </LinearLayout>
    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>
