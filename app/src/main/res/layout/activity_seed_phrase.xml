<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/color_bg_white">

    <!-- Top App Bar -->
    <com.electricdreams.numo.ui.components.NumoTopBar
        android:id="@+id/top_bar"
        android:layout_width="match_parent"
        android:layout_height="@dimen/top_bar_height"
        app:topBarTitle="@string/seed_phrase_toolbar_title"
        app:topBarNavContentDescription="@string/seed_phrase_toolbar_back"
        app:layout_constraintTop_toTopOf="parent" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@id/top_bar">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp">

            <!-- Warning Card -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp"
                android:background="@drawable/bg_warning_card">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <ImageView
                        android:layout_width="@dimen/icon_size_small"
                        android:layout_height="@dimen/icon_size_small"
                        android:layout_marginEnd="@dimen/space_m"
                        android:src="@drawable/ic_warning"
                        app:tint="@color/color_warning" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/seed_phrase_warning_title"
                        android:textSize="16sp"
                        android:textColor="@color/color_text_primary"
                        android:fontFamily="sans-serif-medium" />
                </LinearLayout>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="@string/seed_phrase_warning_body"
                    android:textSize="14sp"
                    android:textColor="@color/color_text_secondary"
                    android:lineSpacingMultiplier="1.3" />

            </LinearLayout>

            <!-- Seed Phrase Title -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="32dp"
                android:layout_marginBottom="8dp"
                android:text="@string/seed_phrase_title"
                android:textSize="15sp"
                android:textColor="@color/color_text_secondary"
                android:fontFamily="sans-serif-medium"
                android:gravity="center" />

            <!-- Show/Hide Button -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/toggle_visibility_button"
                style="@style/Widget.MaterialComponents.Button.TextButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:text="@string/seed_phrase_show_button"
                android:textSize="14sp"
                android:textColor="@color/color_text_primary"
                app:icon="@drawable/ic_visibility"
                app:iconTint="@color/color_text_primary"
                app:iconPadding="8dp" />

            <!-- Seed Words Grid Container -->
            <androidx.gridlayout.widget.GridLayout
                android:id="@+id/seed_words_grid"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:columnCount="2"
                app:rowCount="6"
                app:useDefaultMargins="false"
                android:layout_marginHorizontal="8dp"
                android:layout_marginTop="16dp">

                <!-- Words will be added programmatically -->

            </androidx.gridlayout.widget.GridLayout>

            <!-- Copy Button -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/copy_button"
                style="@style/Widget.Numo.Button.Dialog.Confirm"
                android:layout_width="match_parent"
                android:layout_height="@dimen/button_height"
                android:layout_marginTop="@dimen/space_2xl"
                android:text="@string/seed_phrase_copy_button"
                app:icon="@drawable/ic_content_copy"
                app:iconTint="@color/color_bg_white"
                app:iconGravity="textStart"
                app:iconPadding="@dimen/space_s" />

            <!-- Copy Disclaimer -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="@string/seed_phrase_clipboard_disclaimer"
                android:textSize="13sp"
                android:textColor="@color/color_text_tertiary"
                android:gravity="center" />

        </LinearLayout>
    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>
