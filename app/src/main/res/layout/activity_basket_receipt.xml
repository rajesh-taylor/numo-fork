<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/color_bg_white">

    <!-- Top App Bar -->
    <com.electricdreams.numo.ui.components.NumoTopBar
        android:id="@+id/top_bar"
        android:layout_width="match_parent"
        android:layout_height="@dimen/top_bar_height"
        app:topBarTitle="@string/basket_receipt_title"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- Scrollable Content -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:fillViewport="true"
        android:clipToPadding="false"
        app:layout_constraintTop_toBottomOf="@id/top_bar"
        app:layout_constraintBottom_toTopOf="@id/print_button">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="@dimen/space_2xl">

            <!-- Hero Section -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center_horizontal"
                android:paddingHorizontal="@dimen/margin_screen_horizontal"
                android:paddingVertical="@dimen/space_xl">

                <!-- Total Amount -->
                <TextView
                    android:id="@+id/total_amount"
                    style="@style/Text.Heading1"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textAlignment="center"
                    tools:text="$74.97" />

                <!-- Subtitle (fiat/sats equivalent or VAT info) -->
                <TextView
                    android:id="@+id/total_subtitle"
                    style="@style/Text.Caption"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/space_xs"
                    android:visibility="gone"
                    tools:visibility="visible"
                    tools:text="≈ $14.50 • incl. $2.42 VAT" />

                <!-- Date/Time -->
                <TextView
                    android:id="@+id/checkout_date"
                    style="@style/Text.Caption"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/space_xs"
                    tools:text="Nov 26, 2024 at 2:30 PM" />

            </LinearLayout>

            <!-- ==================== -->
            <!-- DETAILS SECTION      -->
            <!-- ==================== -->
            <TextView
                style="@style/Text.SectionHeader"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingHorizontal="@dimen/margin_screen_horizontal"
                android:paddingTop="@dimen/space_l"
                android:paddingBottom="@dimen/row_padding_vertical"
                android:text="@string/basket_receipt_details_header" />

            <!-- Payment Type Row -->
            <LinearLayout
                android:id="@+id/row_payment_type"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingVertical="@dimen/row_padding_vertical"
                android:paddingHorizontal="@dimen/margin_screen_horizontal">

                <TextView
                    style="@style/Text.RowTitle"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/basket_receipt_payment_type_label" />

                <TextView
                    android:id="@+id/detail_payment_type"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textAppearance="@style/Text.RowSubtitle"
                    tools:text="Lightning" />

            </LinearLayout>

            <!-- Mint Row -->
            <LinearLayout
                android:id="@+id/row_mint"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingVertical="@dimen/row_padding_vertical"
                android:paddingHorizontal="@dimen/margin_screen_horizontal"
                android:visibility="gone">

                <TextView
                    style="@style/Text.RowTitle"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/basket_receipt_mint_label" />

                <TextView
                    android:id="@+id/detail_mint"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:maxWidth="200dp"
                    android:textAppearance="@style/Text.RowSubtitle"
                    android:textAlignment="textEnd"
                    android:maxLines="1"
                    android:ellipsize="middle"
                    tools:text="mint.minibits.cash" />

            </LinearLayout>

            <!-- Transaction ID Row -->
            <LinearLayout
                android:id="@+id/row_transaction_id"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingVertical="@dimen/row_padding_vertical"
                android:paddingHorizontal="@dimen/margin_screen_horizontal"
                android:visibility="gone">

                <TextView
                    style="@style/Text.RowTitle"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/basket_receipt_transaction_id_label" />

                <TextView
                    android:id="@+id/detail_transaction_id"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:maxWidth="180dp"
                    android:textAppearance="@style/Text.RowSubtitle"
                    android:textAlignment="textEnd"
                    android:maxLines="1"
                    android:ellipsize="middle"
                    tools:text="lnbc1pvjluez…" />

            </LinearLayout>

            <!-- ==================== -->
            <!-- ITEMS SECTION        -->
            <!-- ==================== -->
            <LinearLayout
                android:id="@+id/breakdown_container"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <!-- Items Section Header -->
                <TextView
                    android:id="@+id/items_header"
                    style="@style/Text.SectionHeader"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:paddingHorizontal="@dimen/margin_screen_horizontal"
                    android:paddingTop="@dimen/section_gap"
                    android:paddingBottom="@dimen/row_padding_vertical"
                    android:text="@string/basket_receipt_items_header_default"
                    tools:text="3 ITEMS" />

                <!-- Items List Container -->
                <LinearLayout
                    android:id="@+id/items_container"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_marginHorizontal="@dimen/margin_screen_horizontal"
                    android:background="@drawable/bg_rounded_card_large"
                    android:clipChildren="false"
                    android:clipToPadding="false" />

                <!-- Totals Section Header -->
                <TextView
                    style="@style/Text.SectionHeader"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:paddingHorizontal="@dimen/margin_screen_horizontal"
                    android:paddingTop="@dimen/section_gap"
                    android:paddingBottom="@dimen/row_padding_vertical"
                    android:text="@string/basket_receipt_total_label" />

                <!-- Totals Section -->
                <LinearLayout
                    android:id="@+id/totals_container"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <!-- Subtotal Row (Net) -->
                    <LinearLayout
                        android:id="@+id/subtotal_row"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:paddingVertical="@dimen/row_padding_vertical"
                        android:paddingHorizontal="@dimen/margin_screen_horizontal"
                        android:visibility="gone"
                        android:gravity="center_vertical">

                        <TextView
                            android:id="@+id/subtotal_label"
                            style="@style/Text.RowTitle"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@string/basket_receipt_subtotal_label" />

                        <TextView
                            android:id="@+id/subtotal_value"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textAppearance="@style/Text.RowSubtitle" />

                    </LinearLayout>

                    <!-- VAT Breakdown Container -->
                    <LinearLayout
                        android:id="@+id/vat_breakdown_container"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:paddingHorizontal="@dimen/margin_screen_horizontal" />

                    <!-- Sats Items Row (for mixed baskets) -->
                    <LinearLayout
                        android:id="@+id/sats_items_row"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:paddingVertical="@dimen/row_padding_vertical"
                        android:paddingHorizontal="@dimen/margin_screen_horizontal"
                        android:visibility="gone">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical">

                            <TextView
                                style="@style/Text.RowTitle"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="@string/basket_receipt_bitcoin_items_label" />

                            <TextView
                                android:id="@+id/sats_items_value"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:textAppearance="@style/Text.RowSubtitle" />

                        </LinearLayout>

                        <TextView
                            android:id="@+id/sats_items_equiv"
                            style="@style/Text.Caption"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/row_subtitle_gap"
                            android:gravity="end"
                            android:visibility="gone"
                            tools:text="≈ $50.00" />

                    </LinearLayout>

                    <!-- Final Total Row -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:paddingVertical="@dimen/row_padding_vertical"
                        android:paddingHorizontal="@dimen/margin_screen_horizontal"
                        android:gravity="center_vertical">

                        <TextView
                            android:id="@+id/final_total_label"
                            style="@style/Text.RowTitle"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@string/basket_receipt_subtotal_amount_label" />

                        <TextView
                            android:id="@+id/final_total_value"
                            style="@style/Text.RowTitle"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            tools:text="$74.97" />

                    </LinearLayout>

                    <!-- Sats Equivalent (if applicable) -->
                    <TextView
                        android:id="@+id/sats_equivalent"
                        style="@style/Text.Caption"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:paddingHorizontal="@dimen/margin_screen_horizontal"
                        android:gravity="end"
                        android:visibility="gone"
                        tools:text="≈ ₿74,970" />

                </LinearLayout>

                <!-- Payment Section Header -->
                <TextView
                    style="@style/Text.SectionHeader"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:paddingHorizontal="@dimen/margin_screen_horizontal"
                    android:paddingTop="@dimen/section_gap"
                    android:paddingBottom="@dimen/row_padding_vertical"
                    android:text="@string/basket_receipt_paid_label" />

                <!-- Payment Info Row -->
                <LinearLayout
                    android:id="@+id/payment_info_container"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:paddingVertical="@dimen/row_padding_vertical"
                    android:paddingHorizontal="@dimen/margin_screen_horizontal"
                    android:gravity="center_vertical">

                    <TextView
                        style="@style/Text.RowTitle"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/basket_receipt_amount_received_label" />

                    <TextView
                        android:id="@+id/paid_amount"
                        style="@style/Text.RowTitle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="@color/color_success_green"
                        tools:text="₿74,970" />

                </LinearLayout>

            </LinearLayout> <!-- end breakdown_container -->

        </LinearLayout>

    </ScrollView>

    <!-- Print Receipt Button (pinned at bottom) -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/print_button"
        style="@style/Widget.Numo.Button.Dialog.Confirm"
        android:layout_width="match_parent"
        android:layout_height="@dimen/button_height"
        android:layout_marginHorizontal="@dimen/margin_screen_horizontal"
        android:layout_marginBottom="@dimen/space_xl"
        android:text="@string/basket_receipt_print_button"
        app:icon="@drawable/ic_print"
        app:iconGravity="textStart"
        app:iconPadding="@dimen/space_s"
        app:layout_constraintBottom_toBottomOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
