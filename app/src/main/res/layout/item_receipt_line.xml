<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:paddingHorizontal="@dimen/space_l"
    android:paddingVertical="@dimen/row_padding_vertical">

    <!-- Main Item Row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="top">

        <!-- Quantity Badge -->
        <TextView
            android:id="@+id/item_quantity"
            android:layout_width="@dimen/icon_size_xs"
            android:layout_height="@dimen/icon_size_xs"
            android:background="@drawable/bg_quantity_badge"
            android:gravity="center"
            style="@style/Text.Caption"
            android:textColor="@color/color_text_primary"
            android:fontFamily="sans-serif-medium"
            tools:text="2" />

        <!-- Item Details -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginStart="@dimen/space_m"
            android:layout_marginEnd="@dimen/space_m">

            <!-- Item Name -->
            <TextView
                android:id="@+id/item_name"
                style="@style/Text.RowTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:ellipsize="end"
                android:maxLines="2"
                tools:text="Cappuccino - Large" />

            <!-- Unit Price -->
            <TextView
                android:id="@+id/item_unit_price"
                style="@style/Text.Caption"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/row_subtitle_gap"
                tools:text="$4.50 each" />

        </LinearLayout>

        <!-- Line Total -->
        <TextView
            android:id="@+id/item_total"
            style="@style/Text.RowTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            tools:text="$9.00" />

    </LinearLayout>

    <!-- VAT Detail (optional - only shown if VAT applies) -->
    <LinearLayout
        android:id="@+id/vat_detail_row"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="@dimen/space_xs"
        android:layout_marginStart="@dimen/row_icon_size"
        android:visibility="gone"
        tools:visibility="visible">

        <TextView
            android:id="@+id/vat_label"
            style="@style/Text.Caption"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            tools:text="incl. 20% VAT" />

        <TextView
            android:id="@+id/vat_amount"
            style="@style/Text.Caption"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            tools:text="$1.50" />

    </LinearLayout>

</LinearLayout>
