<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:paddingVertical="@dimen/space_m"
    android:paddingHorizontal="@dimen/space_l"
    android:background="@drawable/bg_seed_word"
    android:layout_marginBottom="@dimen/space_s">

    <!-- Status Icon -->
    <FrameLayout
        android:layout_width="24dp"
        android:layout_height="24dp"
        android:layout_marginEnd="@dimen/space_m">

        <ProgressBar
            android:id="@+id/mint_spinner"
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:layout_gravity="center"
            android:indeterminate="true"
            android:indeterminateTint="@color/color_text_secondary" />

        <ImageView
            android:id="@+id/mint_status_icon"
        android:importantForAccessibility="no"
            android:layout_width="@dimen/icon_size_small"
            android:layout_height="@dimen/icon_size_small"
            android:layout_gravity="center"
            android:visibility="gone" />

    </FrameLayout>

    <!-- Mint Info -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/mint_name"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/mint_restore_name_placeholder"
            android:textAppearance="@style/Text.Chip"
            android:maxLines="1"
            android:ellipsize="end" />

        <TextView
            android:id="@+id/mint_status"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/mint_restore_status_restoring"
            android:textAppearance="@style/Text.Caption"
            android:textColor="@color/color_text_secondary"
            android:layout_marginTop="2dp" />

    </LinearLayout>

    <!-- Balance Change -->
    <TextView
        android:id="@+id/balance_change"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/mint_restore_balance_change_placeholder"
        android:textAppearance="@style/Text.Chip"
        android:textColor="@color/color_success_green"
        android:visibility="gone" />

</LinearLayout>
