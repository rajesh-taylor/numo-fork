<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/numo_navy">

    <!-- ======================== -->
    <!-- STEP 1: WELCOME SCREEN   -->
    <!-- ======================== -->
    <FrameLayout
        android:id="@+id/welcome_container"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipChildren="false"
        android:visibility="gone">

        <!-- Background (starts white, transitions to navy via animator) -->
        <View
            android:id="@+id/welcome_background_overlay"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@android:color/white" />

        <!-- Navy overlay for circular reveal transition -->
        <View
            android:id="@+id/welcome_circular_reveal"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@color/numo_navy"
            android:visibility="invisible" />

        <!-- Scrolling Items container (rendered behind text) -->
        <FrameLayout
            android:id="@+id/scrolling_items_container"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:clipChildren="false"
            android:clipToPadding="false" />

        <!-- Content Layer (on top of emojis) -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:gravity="center_horizontal"
            android:paddingHorizontal="32dp">

            <Space
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1" />

            <!-- Numo Wordmark (per-letter white + green overlay for color fill animation) -->
            <FrameLayout
                android:layout_width="200dp"
                android:layout_height="88dp"
                android:clipChildren="false"
                android:clipToPadding="false">

                <!-- Per-letter wordmark views (stagger-animated individually) -->
                <LinearLayout
                    android:id="@+id/welcome_wordmark_letters"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="horizontal"
                    android:clipChildren="false"
                    android:clipToPadding="false">

                    <ImageView
                        android:id="@+id/welcome_letter_n"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="41.4"
                        android:src="@drawable/ic_numo_letter_n"
                        android:scaleType="fitCenter"
                        android:contentDescription="@string/app_name"
                        android:alpha="0" />

                    <Space
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="6.93" />

                    <ImageView
                        android:id="@+id/welcome_letter_u"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="39.36"
                        android:src="@drawable/ic_numo_letter_u"
                        android:scaleType="fitCenter"
                        android:alpha="0" />

                    <Space
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="7.0" />

                    <ImageView
                        android:id="@+id/welcome_letter_m"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="54.72"
                        android:src="@drawable/ic_numo_letter_m"
                        android:scaleType="fitCenter"
                        android:alpha="0" />

                    <Space
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="6.49" />

                    <ImageView
                        android:id="@+id/welcome_letter_o"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="40.08"
                        android:src="@drawable/ic_numo_letter_o"
                        android:scaleType="fitCenter"
                        android:alpha="0" />

                </LinearLayout>

            </FrameLayout>

            <!-- Tagline (color set by animator: starts navy, transitions to white) -->
            <TextView
                android:id="@+id/welcome_tagline"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:text="@string/onboarding_welcome_tagline"
                android:textSize="17sp"
                android:lineHeight="24sp"
                android:textColor="@color/color_text_on_dark"
                android:gravity="center"
                android:fontFamily="sans-serif-medium"
                android:alpha="0"
                android:paddingHorizontal="16dp" />

            <Space
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1" />

            <!-- Get Started button (white bg, navy text — visible after color transition) -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/accept_button"
                android:layout_width="match_parent"
                android:layout_height="64dp"
                android:text="@string/onboarding_get_started"
                android:textSize="18sp"
                android:textColor="@color/numo_navy"
                android:textAllCaps="false"
                android:alpha="0"
                android:paddingVertical="4dp"
                android:stateListAnimator="@null"
                app:cornerRadius="32dp"
                app:backgroundTint="@color/color_text_on_dark"
                app:elevation="0dp" />

            <!-- Terms Text (below button) -->
            <TextView
                android:id="@+id/terms_text"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="@string/onboarding_terms_text"
                android:textSize="13sp"
                android:textColor="@color/color_text_on_dark"
                android:alpha="0"
                android:gravity="center"
                android:paddingHorizontal="16dp" />

            <Space
                android:layout_width="match_parent"
                android:layout_height="32dp" />

        </LinearLayout>

    </FrameLayout>

    <!-- ======================== -->
    <!-- STEP 2: CHOOSE PATH      -->
    <!-- ======================== -->
    <FrameLayout
        android:id="@+id/choose_path_container"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/numo_navy"
        android:visibility="gone">

        <!-- Scrollable content + teaser -->
        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:fillViewport="true"
            android:scrollbars="none">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <!-- Setup content -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingHorizontal="24dp"
                    android:paddingTop="48dp">

                    <!-- Title -->
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/onboarding_setup_title"
                        android:textSize="32sp"
                        android:textColor="@color/color_text_on_dark"
                        android:fontFamily="sans-serif-black"
                        android:textAllCaps="true"
                        android:letterSpacing="-0.03"
                        android:gravity="center"
                        android:lineSpacingMultiplier="1.05" />

                    <Space
                        android:layout_width="match_parent"
                        android:layout_height="48dp" />

                    <!-- Create New Wallet (primary CTA) -->
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/create_wallet_button"
                        style="@style/Widget.Numo.Button.Onboarding.Primary"
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:textSize="16sp"
                        android:text="@string/onboarding_create_wallet_title" />

                    <Space
                        android:layout_width="match_parent"
                        android:layout_height="24dp" />

                    <!-- Restore from Backup (secondary action) -->
                    <LinearLayout
                        android:id="@+id/restore_wallet_button"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center"
                        android:paddingVertical="12dp"
                        android:clickable="true"
                        android:focusable="true"
                        android:background="?attr/selectableItemBackground">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/onboarding_restore_wallet_title"
                            android:textSize="14sp"
                            android:textColor="@color/color_scrim_on_dark"
                            android:fontFamily="sans-serif" />

                    </LinearLayout>

                </LinearLayout>

                <!-- Flexible spacer pushes teaser to bottom on large screens -->
                <Space
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_weight="1" />

                <!-- Teaser card -->
                <FrameLayout
                    android:id="@+id/teaser_card"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:paddingHorizontal="16dp"
                    android:paddingBottom="34dp"
                    android:clickable="true"
                    android:focusable="true">

                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        app:cardCornerRadius="20dp"
                        app:cardElevation="0dp"
                        app:cardBackgroundColor="@color/numo_fluorescent_green">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical">

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="vertical"
                                android:paddingTop="20dp"
                                android:paddingHorizontal="24dp"
                                android:paddingBottom="12dp">

                                <!-- Teaser tagline -->
                                <TextView
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:text="@string/explainer_teaser_title"
                                    android:textSize="24sp"
                                    android:fontFamily="sans-serif-black"
                                    android:textColor="@color/numo_navy"
                                    android:textAllCaps="true"
                                    android:letterSpacing="-0.03"
                                    android:lineSpacingMultiplier="1.05" />

                            </LinearLayout>

                            <ImageView
                                android:id="@+id/teaser_illustration"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:adjustViewBounds="true"
                                android:src="@drawable/img_tap_to_pay"
                                android:scaleType="fitCenter"
                                android:contentDescription="@string/explainer_image_placeholder" />

                        </LinearLayout>

                    </com.google.android.material.card.MaterialCardView>

                </FrameLayout>

            </LinearLayout>

        </ScrollView>

        <!-- Explainer overlay -->
        <FrameLayout
            android:id="@+id/explainer_overlay"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:visibility="gone">

            <!-- Backdrop -->
            <View
                android:id="@+id/explainer_backdrop"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@color/color_scrim_on_light"
                android:alpha="0" />

            <!-- Sheet -->
            <LinearLayout
                android:id="@+id/explainer_sheet"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:background="@color/numo_navy"
                android:translationY="2000dp">

                <!-- Close button -->
                <FrameLayout
                    android:id="@+id/explainer_close_container"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:paddingStart="20dp">

                    <ImageView
                        android:id="@+id/explainer_close_btn"
                        android:layout_width="44dp"
                        android:layout_height="44dp"
                        android:padding="10dp"
                        android:src="@drawable/ic_close"
                        app:tint="@color/color_text_on_dark"
                        android:alpha="0.7"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        android:clickable="true"
                        android:focusable="true"
                        android:contentDescription="@string/navigation_drawer_close" />

                </FrameLayout>

                <!-- Slides ViewPager -->
                <androidx.viewpager2.widget.ViewPager2
                    android:id="@+id/explainer_view_pager"
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_weight="1"
                    android:orientation="vertical" />

                <!-- Swipe hint chevrons and Create Wallet Button -->
                <FrameLayout
                    android:id="@+id/explainer_bottom_container"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">

                    <!-- Swipe hint chevrons -->
                    <LinearLayout
                        android:id="@+id/chevron_hint_container"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:orientation="vertical"
                        android:gravity="center_horizontal">

                        <ImageView
                            android:id="@+id/chevron_hint_1"
                            android:layout_width="24dp"
                            android:layout_height="14dp"
                            android:layout_marginTop="16dp"
                            android:src="@drawable/ic_chevron_down_hint"
                            android:alpha="0.12"
                            android:contentDescription="@null" />

                        <ImageView
                            android:id="@+id/chevron_hint_2"
                            android:layout_width="24dp"
                            android:layout_height="14dp"
                            android:layout_marginTop="-6dp"
                            android:src="@drawable/ic_chevron_down_hint"
                            android:alpha="0.12"
                            android:contentDescription="@null" />

                        <ImageView
                            android:id="@+id/chevron_hint_3"
                            android:layout_width="24dp"
                            android:layout_height="14dp"
                            android:layout_marginTop="-6dp"
                            android:layout_marginBottom="16dp"
                            android:src="@drawable/ic_chevron_down_hint"
                            android:alpha="0.12"
                            android:contentDescription="@null" />

                    </LinearLayout>

                    <!-- Create Wallet Button (Explainer) -->
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/explainer_create_wallet_button"
                        style="@style/Widget.Numo.Button.Onboarding.Primary"
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:layout_gravity="center"
                        android:layout_marginHorizontal="24dp"
                        android:text="@string/onboarding_create_wallet_title"
                        android:alpha="0"
                        android:visibility="invisible" />

                </FrameLayout>

            </LinearLayout>

        </FrameLayout>

    </FrameLayout>

    <!-- ======================== -->
    <!-- STEP 3: ENTER SEED       -->
    <!-- ======================== -->
    <FrameLayout
        android:id="@+id/enter_seed_container"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="gone">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical">

            <!-- Back button -->
            <ImageView
                android:id="@+id/seed_back_button"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_marginStart="8dp"
                android:layout_marginTop="8dp"
                android:padding="12dp"
                android:src="@drawable/ic_chevron_back"
                android:background="?attr/selectableItemBackgroundBorderless"
                app:tint="@color/color_text_on_dark_subtle"
                android:contentDescription="@string/onboarding_seed_toolbar_back" />

            <!-- Title -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingHorizontal="24dp"
                android:paddingTop="8dp"
                android:text="@string/onboarding_seed_toolbar_title"
                android:textSize="32sp"
                android:textColor="@color/color_text_on_dark"
                android:fontFamily="sans-serif-black"
                android:textAllCaps="true"
                android:letterSpacing="-0.03"
                android:lineSpacingMultiplier="1.05" />

            <ScrollView
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:fillViewport="true">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="vertical"
                    android:paddingHorizontal="20dp"
                    android:paddingBottom="32dp">

                    <!-- Instructions -->
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:text="@string/onboarding_seed_instruction_title"
                        android:textSize="24sp"
                        android:textColor="@color/color_text_on_dark"
                        android:fontFamily="sans-serif-medium" />

                    <!-- Seed Input Grid -->
                    <androidx.gridlayout.widget.GridLayout
                        android:id="@+id/seed_input_grid"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="24dp"
                        app:columnCount="2"
                        app:rowCount="6" />

                    <!-- Spacer pushes buttons to bottom when space allows -->
                    <View
                        android:layout_width="0dp"
                        android:layout_height="0dp"
                        android:layout_weight="1" />

                    <!-- Paste Button (tertiary) -->
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/paste_button"
                        style="@style/Widget.Numo.Button.Onboarding.Tertiary"
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:layout_marginTop="24dp"
                        android:text="@string/onboarding_seed_paste_button" />

                    <!-- Continue Button (primary) -->
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/seed_continue_button"
                        style="@style/Widget.Numo.Button.Onboarding.Primary"
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:layout_marginTop="12dp"
                        android:text="@string/onboarding_seed_continue"
                        android:enabled="false"
                        android:alpha="0.5" />

                </LinearLayout>
            </ScrollView>
        </LinearLayout>
    </FrameLayout>

    <!-- ======================== -->
    <!-- STEP 4a: GENERATING      -->
    <!-- ======================== -->
    <FrameLayout
        android:id="@+id/generating_container"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="gone">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:gravity="center"
            android:paddingHorizontal="48dp">

            <ProgressBar
                android:layout_width="64dp"
                android:layout_height="64dp"
                android:indeterminate="true"
                android:indeterminateTint="@color/numo_fluorescent_green" />

            <TextView
                android:id="@+id/generating_status"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:text="@string/onboarding_status_creating_wallet"
                android:textSize="17sp"
                android:textColor="@color/color_text_on_dark"
                android:gravity="center" />

        </LinearLayout>
    </FrameLayout>

    <!-- ======================== -->
    <!-- STEP 4b: FETCHING BACKUP -->
    <!-- ======================== -->
    <FrameLayout
        android:id="@+id/fetching_container"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="gone">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:gravity="center"
            android:paddingHorizontal="48dp">

            <ProgressBar
                android:layout_width="64dp"
                android:layout_height="64dp"
                android:indeterminate="true"
                android:indeterminateTint="@color/numo_fluorescent_green" />

            <TextView
                android:id="@+id/fetching_status"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:text="@string/onboarding_status_restoring_wallet"
                android:textSize="17sp"
                android:textColor="@color/color_text_on_dark"
                android:gravity="center" />

        </LinearLayout>
    </FrameLayout>

    <!-- ======================== -->
    <!-- STEP 5: REVIEW MINTS     -->
    <!-- ======================== -->
    <FrameLayout
        android:id="@+id/review_mints_container"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="gone">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical">

            <!-- Back button -->
            <ImageView
                android:id="@+id/mints_back_button"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_marginStart="8dp"
                android:layout_marginTop="8dp"
                android:padding="12dp"
                android:src="@drawable/ic_chevron_back"
                android:background="?attr/selectableItemBackgroundBorderless"
                app:tint="@color/color_text_on_dark_subtle"
                android:contentDescription="@string/onboarding_mints_toolbar_back" />

            <!-- Title -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingHorizontal="24dp"
                android:paddingTop="8dp"
                android:text="@string/onboarding_mints_toolbar_title"
                android:textSize="32sp"
                android:textColor="@color/color_text_on_dark"
                android:fontFamily="sans-serif-black"
                android:textAllCaps="true"
                android:letterSpacing="-0.03"
                android:lineSpacingMultiplier="1.05" />

            <!-- Backup Status Card -->
            <LinearLayout
                android:id="@+id/backup_status_card"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:background="@color/numo_navy"
                android:padding="16dp"
                android:layout_marginTop="8dp"
                android:layout_marginHorizontal="20dp"
                android:gravity="center_vertical"
                android:visibility="gone">

                <ImageView
                    android:id="@+id/backup_status_icon"
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:src="@drawable/ic_cloud_done"
                    app:tint="@color/numo_fluorescent_green" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginStart="14dp">

                    <TextView
                        android:id="@+id/backup_status_title"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/onboarding_backup_found_title"
                        android:textSize="15sp"
                        android:textColor="@color/numo_fluorescent_green"
                        android:fontFamily="sans-serif-medium" />

                    <TextView
                        android:id="@+id/backup_status_subtitle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:text="@string/onboarding_backup_found_subtitle"
                        android:textSize="13sp"
                        android:textColor="@color/color_text_on_dark_subtle" />

                </LinearLayout>

            </LinearLayout>

            <!-- Mints RecyclerView -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/mints_recycler_view"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:paddingHorizontal="20dp"
                android:paddingTop="12dp"
                android:paddingBottom="8dp"
                android:clipToPadding="false" />

            <!-- Fixed Bottom Buttons -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingHorizontal="20dp"
                android:paddingTop="12dp"
                android:paddingBottom="32dp"
                android:background="@color/numo_navy">

                <!-- Continue - primary button (matches seed_continue_button style) -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/mints_continue_button"
                    style="@style/Widget.Numo.Button.Onboarding.Primary"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:text="@string/onboarding_mints_continue_new_wallet" />

            </LinearLayout>
        </LinearLayout>
    </FrameLayout>

    <!-- ======================== -->
    <!-- STEP 6: RESTORING        -->
    <!-- ======================== -->
    <FrameLayout
        android:id="@+id/restoring_container"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="gone">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical">

            <!-- Top Bar -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingHorizontal="16dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/onboarding_restoring_title"
                    android:textSize="17sp"
                    android:textColor="@color/color_text_on_dark"
                    android:fontFamily="sans-serif-medium"
                    android:gravity="center" />

            </LinearLayout>

            <ScrollView
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:fillViewport="true">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingHorizontal="20dp"
                    android:paddingTop="24dp"
                    android:paddingBottom="24dp"
                    android:gravity="center_horizontal">

                    <ProgressBar
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:indeterminate="true"
                        android:indeterminateTint="@color/numo_fluorescent_green" />

                    <TextView
                        android:id="@+id/restoring_status"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:text="@string/onboarding_restoring_initializing"
                        android:textSize="15sp"
                        android:textColor="@color/color_text_on_dark_subtle"
                        android:gravity="center" />

                    <!-- Mint Progress Items -->
                    <LinearLayout
                        android:id="@+id/mint_progress_container"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:layout_marginTop="32dp" />

                </LinearLayout>
            </ScrollView>
        </LinearLayout>
    </FrameLayout>

    <!-- ======================== -->
    <!-- STEP 7: SUCCESS          -->
    <!-- ======================== -->
    <FrameLayout
        android:id="@+id/success_container"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="gone">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:paddingHorizontal="24dp">

            <Space
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="0.2" />

            <!-- Success Checkmark (animated, matches payment success style) -->
            <com.electricdreams.numo.ui.animation.CheckmarkAnimationView
                android:id="@+id/success_checkmark"
                android:layout_width="88dp"
                android:layout_height="88dp"
                android:layout_gravity="center_horizontal"
                android:contentDescription="@string/payment_received_success_icon_description" />

            <!-- Success Text -->
            <TextView
                android:id="@+id/success_title"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="32dp"
                android:text="@string/onboarding_success_created_title"
                android:textSize="28sp"
                android:textColor="@color/color_text_on_dark"
                android:fontFamily="sans-serif-medium"
                android:gravity="center" />

            <TextView
                android:id="@+id/success_subtitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="@string/onboarding_success_created_subtitle"
                android:textSize="16sp"
                android:textColor="@color/color_text_on_dark_subtle"
                android:gravity="center" />

            <Space
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="0.1" />

            <!-- Balance Changes Section (Restore only) -->
            <LinearLayout
                android:id="@+id/success_balance_section"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/onboarding_success_balance_by_mint"
                    android:textSize="12sp"
                    android:textColor="@color/color_text_on_dark_faint"
                    android:letterSpacing="0.1"
                    android:layout_marginBottom="12dp" />

                <LinearLayout
                    android:id="@+id/balance_changes_container"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical" />

            </LinearLayout>

            <Space
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="0.3" />

            <!-- Enter Wallet Button -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/enter_wallet_button"
                style="@style/Widget.Numo.Button.Onboarding.Primary"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:text="@string/onboarding_enter_wallet_button" />

            <Space
                android:layout_width="match_parent"
                android:layout_height="32dp" />

        </LinearLayout>
    </FrameLayout>

</FrameLayout>
