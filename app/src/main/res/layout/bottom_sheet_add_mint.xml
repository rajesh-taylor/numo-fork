<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingBottom="@dimen/space_2xl">

        <!-- Drag Handle -->
        <View
            android:layout_width="36dp"
            android:layout_height="4dp"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="@dimen/space_m"
            android:background="@color/color_divider" />

        <!-- Title -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/margin_screen_horizontal"
            android:paddingHorizontal="@dimen/space_xl"
            android:text="@string/onboarding_add_mint_sheet_title"
            android:textAppearance="@style/Text.DialogTitle" />

        <!-- URL Input -->
        <com.google.android.material.textfield.TextInputLayout
            style="@style/Widget.Numo.TextInputLayout.OutlinedBox"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/margin_screen_horizontal"
            android:layout_marginHorizontal="@dimen/space_xl">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/mint_url_input"
                android:layout_width="match_parent"
                android:layout_height="@dimen/button_height"
                android:hint="@string/onboarding_add_mint_url_hint"
                android:textSize="15sp"
                android:textColor="@color/color_text_primary"
                android:textColorHint="@color/color_text_tertiary"
                android:inputType="textUri"
                android:singleLine="true"
                android:imeOptions="actionDone"
                android:importantForAutofill="no" />

        </com.google.android.material.textfield.TextInputLayout>

        <!-- Add Button / Loading Container -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="@dimen/button_height"
            android:layout_marginTop="@dimen/space_m"
            android:layout_marginHorizontal="@dimen/space_xl">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/add_mint_button"
                style="@style/Widget.Numo.Button.Dialog.Confirm"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:text="@string/onboarding_add_mint_button"
                android:enabled="false" />

            <LinearLayout
                android:id="@+id/add_mint_loading"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="horizontal"
                android:gravity="center"
                android:visibility="gone">

                <ProgressBar
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:indeterminate="true"
                    android:indeterminateTint="@color/numo_fluorescent_green" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="@dimen/space_m"
                    android:text="@string/onboarding_add_mint_loading"
                    android:textAppearance="@style/Text.Body" />

            </LinearLayout>

        </FrameLayout>

        <!-- Scan QR Code Button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/scan_qr_button"
            style="@style/Widget.Button.Secondary.Outlined"
            android:layout_width="match_parent"
            android:layout_height="@dimen/button_height"
            android:layout_marginTop="@dimen/space_m"
            android:layout_marginHorizontal="@dimen/space_xl"
            android:text="@string/onboarding_add_mint_scan_qr"
            android:textSize="17sp"
            android:textColor="@color/color_text_primary"
            app:cornerRadius="@dimen/radius_pill"
            app:icon="@drawable/ic_qr_scan"
            app:iconGravity="textStart"
            app:iconPadding="@dimen/space_s"
            app:iconTint="@color/color_text_primary" />

    </LinearLayout>

</androidx.core.widget.NestedScrollView>
