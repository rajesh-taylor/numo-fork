<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/coordinator_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/color_bg_white"
    android:fitsSystemWindows="true">

    <!-- Main Content Container (hidden when showing animated empty state) -->
    <FrameLayout
        android:id="@+id/main_content"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="gone"
        tools:visibility="visible">

        <!-- Scrollable Content -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical">

            <!-- Top Bar with Search (fixed at top) -->
            <LinearLayout
                android:id="@+id/top_bar"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@color/color_bg_white"
                android:paddingTop="@dimen/space_s">

                <!-- Header Row -->
                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/top_bar_height"
                    android:paddingHorizontal="@dimen/space_l">

                    <ImageButton
                        android:id="@+id/back_button"
                        android:layout_width="@dimen/icon_size_large"
                        android:layout_height="@dimen/icon_size_large"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        android:contentDescription="@string/item_selection_toolbar_back"
                        android:padding="@dimen/space_m"
                        android:src="@drawable/ic_chevron_back"
                        app:tint="@color/color_text_primary"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent" />

                    <TextView
                        android:id="@+id/toolbar_title"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/item_selection_toolbar_title"
                        android:textAppearance="@style/Text.Title"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent" />

                    <!-- Saved Baskets Button (top right) -->
                    <TextView
                        android:id="@+id/saved_baskets_button"
                        android:layout_width="wrap_content"
                        android:layout_height="36dp"
                        android:gravity="center"
                        android:paddingHorizontal="@dimen/space_m"
                        android:text="@string/item_selection_saved_baskets_button"
                        android:textAppearance="@style/Text.Link"
                        android:textColor="@color/color_accent_blue"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintTop_toTopOf="parent" />

                </androidx.constraintlayout.widget.ConstraintLayout>

                <!-- Search Bar with Barcode Scanner / Clear Button -->
                <LinearLayout
                    android:id="@+id/search_bar_container"
                    android:layout_width="match_parent"
                    android:layout_height="44dp"
                    android:layout_marginHorizontal="@dimen/space_l"
                    android:layout_marginTop="@dimen/space_s"
                    android:background="@drawable/bg_search_field"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingStart="@dimen/space_m"
                    android:paddingEnd="@dimen/space_xs">

                    <ImageView
                        android:id="@+id/search_icon"
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:contentDescription="@string/item_selection_search_icon_description"
                        android:src="@drawable/ic_search"
                        app:tint="@color/color_text_tertiary" />

                    <!-- Category Badge (shown when category selected) -->
                    <TextView
                        android:id="@+id/category_badge"
                        android:layout_width="wrap_content"
                        android:layout_height="24dp"
                        android:layout_marginStart="@dimen/space_s"
                        android:background="@drawable/bg_category_badge"
                        android:gravity="center"
                        android:paddingHorizontal="@dimen/space_s"
                        android:textAppearance="@style/Text.Caption"
                        android:fontFamily="sans-serif-medium"
                        android:textColor="@color/color_bg_white"
                        android:maxLines="1"
                        android:ellipsize="end"
                        android:visibility="gone"
                        tools:text="Electronics"
                        tools:visibility="visible" />

                    <EditText
                        android:id="@+id/search_input"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:layout_marginStart="@dimen/space_s"
                        android:background="@null"
                        android:hint="@string/item_selection_search_hint"
                        android:imeOptions="actionSearch"
                        android:inputType="text"
                        android:maxLines="1"
                        android:textAppearance="@style/Text.Body"
                        android:textColor="@color/color_text_primary"
                        android:textColorHint="@color/color_text_tertiary" />

                    <!-- Scan Button (default) -->
                    <ImageButton
                        android:id="@+id/scan_button"
                        android:layout_width="@dimen/icon_size_medium"
                        android:layout_height="@dimen/icon_size_medium"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        android:contentDescription="@string/item_selection_scan_barcode"
                        android:padding="@dimen/space_s"
                        android:src="@drawable/ic_barcode_scan"
                        app:tint="@color/color_text_secondary" />

                    <!-- Clear Filters Button (shown when filters active) -->
                    <ImageButton
                        android:id="@+id/clear_filters_button"
                        android:layout_width="@dimen/icon_size_medium"
                        android:layout_height="@dimen/icon_size_medium"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        android:contentDescription="@string/item_selection_clear_filters"
                        android:padding="@dimen/space_m"
                        android:src="@drawable/ic_close_circle"
                        app:tint="@color/color_text_secondary"
                        android:visibility="gone" />

                </LinearLayout>

                <!-- Category Chips (shown when search focused and categories exist) -->
                <com.google.android.flexbox.FlexboxLayout
                    android:id="@+id/category_chips_container"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/space_s"
                    android:layout_marginBottom="@dimen/space_xs"
                    android:paddingHorizontal="@dimen/space_l"
                    android:visibility="gone"
                    app:flexWrap="wrap"
                    app:alignItems="flex_start"
                    app:justifyContent="flex_start"
                    tools:visibility="visible" />

                <!-- Spacer below search bar -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="8dp" />

            </LinearLayout>

            <!-- Scrollable items and spacer -->
            <androidx.core.widget.NestedScrollView
                android:id="@+id/main_scroll_view"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:fillViewport="true"
                android:clipToPadding="false">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <!-- Items List Section -->
                    <FrameLayout
                        android:id="@+id/items_container"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:minHeight="300dp">

                        <androidx.recyclerview.widget.RecyclerView
                            android:id="@+id/items_recycler_view"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:clipToPadding="false"
                            android:paddingTop="@dimen/space_s"
                            android:nestedScrollingEnabled="false"
                            tools:listitem="@layout/item_product_selection" />

                        <!-- Simple Empty State (kept for search handler compatibility) -->
                        <LinearLayout
                            android:id="@+id/empty_view"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:gravity="center"
                            android:orientation="vertical"
                            android:padding="@dimen/space_2xl"
                            android:visibility="gone">

                            <ImageView
                                android:layout_width="64dp"
                                android:layout_height="64dp"
                                android:src="@drawable/ic_shopping_bag"
                                app:tint="@color/color_icon_tertiary"
                                android:contentDescription="@string/item_selection_empty_icon_description" />

                            <TextView
                                android:id="@+id/empty_title"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="@dimen/space_l"
                                android:text="@string/item_selection_empty_title"
                                android:textAppearance="@style/Text.RowTitle"
                                android:textColor="@color/color_text_secondary" />

                            <TextView
                                android:id="@+id/empty_subtitle"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="@dimen/space_xs"
                                android:text="@string/item_selection_empty_subtitle"
                                android:textAppearance="@style/Text.Body"
                                android:textColor="@color/color_text_tertiary"
                                android:gravity="center" />

                        </LinearLayout>

                        <!-- No Search Results -->
                        <LinearLayout
                            android:id="@+id/no_results_view"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:gravity="center"
                            android:orientation="vertical"
                            android:padding="@dimen/space_2xl"
                            android:visibility="gone">

                            <ImageView
                                android:layout_width="64dp"
                                android:layout_height="64dp"
                                android:src="@drawable/ic_search"
                                app:tint="@color/color_icon_tertiary"
                                android:contentDescription="@string/item_selection_no_results_icon_description" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="@dimen/space_l"
                                android:text="@string/item_selection_no_results_title"
                                android:textAppearance="@style/Text.RowTitle"
                                android:textColor="@color/color_text_secondary" />

                            <TextView
                                android:id="@+id/no_results_subtitle"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="@dimen/space_xs"
                                android:text="@string/item_selection_no_results_subtitle"
                                android:textAppearance="@style/Text.Body"
                                android:textColor="@color/color_text_tertiary" />

                        </LinearLayout>

                    </FrameLayout>

                    <!-- Bottom spacing so content doesn't sit under basket/checkout -->
                    <View
                        android:id="@+id/bottom_spacer"
                        android:layout_width="match_parent"
                        android:layout_height="140dp" />

                </LinearLayout>

            </androidx.core.widget.NestedScrollView>

        </LinearLayout>

        <!-- Bottom Basket + Checkout (overlay at bottom) -->
        <LinearLayout
            android:id="@+id/bottom_basket_checkout_container"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom"
            android:orientation="vertical"
            android:paddingHorizontal="@dimen/space_l"
            android:paddingBottom="@dimen/space_xl"
            android:paddingTop="@dimen/space_s"
            android:clipToPadding="false"
            android:clipChildren="false">

            <androidx.cardview.widget.CardView
                android:id="@+id/basket_section"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="@color/color_bg_elevated"
                app:cardCornerRadius="@dimen/radius_card"
                app:cardElevation="4dp"
                android:visibility="gone"
                android:clipChildren="true"
                android:clipToPadding="true"
                tools:visibility="visible">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:clipChildren="true"
                    android:clipToPadding="true">

                    <androidx.constraintlayout.widget.ConstraintLayout
                        android:id="@+id/basket_header"
                        android:layout_width="match_parent"
                        android:layout_height="@dimen/top_bar_height"
                        android:paddingHorizontal="@dimen/space_l"
                        android:background="?attr/selectableItemBackground">

                        <ImageView
                            android:id="@+id/basket_icon"
                            android:layout_width="22dp"
                            android:layout_height="22dp"
                            android:src="@drawable/ic_shopping_bag"
                            app:tint="@color/color_text_primary"
                            android:contentDescription="@string/item_selection_basket_icon_description"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toTopOf="parent"
                            app:layout_constraintBottom_toBottomOf="parent" />

                        <TextView
                            android:id="@+id/basket_item_count"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="@dimen/space_s"
                            android:textAppearance="@style/Text.Body"
                            tools:text="3 items"
                            app:layout_constraintStart_toEndOf="@id/basket_icon"
                            app:layout_constraintTop_toTopOf="parent"
                            app:layout_constraintBottom_toBottomOf="parent" />

                        <TextView
                            android:id="@+id/basket_total"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginEnd="@dimen/space_s"
                            android:textAppearance="@style/Text.Subtitle"
                            tools:text="$74.97"
                            app:layout_constraintEnd_toStartOf="@id/basket_chevron"
                            app:layout_constraintTop_toTopOf="parent"
                            app:layout_constraintBottom_toBottomOf="parent" />

                        <ImageView
                            android:id="@+id/basket_chevron"
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:src="@drawable/ic_chevron_up"
                            app:tint="@color/color_text_tertiary"
                            android:contentDescription="@string/item_selection_basket_expand"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintTop_toTopOf="parent"
                            app:layout_constraintBottom_toBottomOf="parent" />

                    </androidx.constraintlayout.widget.ConstraintLayout>

                    <LinearLayout
                        android:id="@+id/basket_expandable_content"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:visibility="gone"
                        tools:visibility="visible">

                        <View
                            android:layout_width="match_parent"
                            android:layout_height="1dp"
                            android:layout_marginHorizontal="@dimen/space_l"
                            android:background="@color/color_divider" />

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="40dp"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:paddingHorizontal="@dimen/space_l">

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="@string/item_selection_basket_title"
                                style="@style/Text.SectionHeader" />

                            <TextView
                                android:id="@+id/basket_undo_button"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:padding="@dimen/space_xs"
                                android:gravity="center_vertical"
                                android:text="@string/item_selection_undo_button_short"
                                android:textAppearance="@style/Text.SecondaryButton"
                                android:background="?attr/selectableItemBackgroundBorderless"
                                android:alpha="0.35" />

                            <TextView
                                android:id="@+id/basket_redo_button"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="@dimen/space_s"
                                android:padding="@dimen/space_xs"
                                android:gravity="center_vertical"
                                android:text="@string/item_selection_redo_button_short"
                                android:textAppearance="@style/Text.SecondaryButton"
                                android:background="?attr/selectableItemBackgroundBorderless"
                                android:alpha="0.35" />

                            <TextView
                                android:id="@+id/clear_basket_button"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="@dimen/space_m"
                                android:padding="@dimen/space_xs"
                                android:text="@string/item_selection_basket_clear"
                                android:textAppearance="@style/Text.SecondaryButton"
                                android:textColor="@color/color_warning_red"
                                android:background="?attr/selectableItemBackgroundBorderless" />

                        </LinearLayout>

                        <androidx.recyclerview.widget.RecyclerView
                            android:id="@+id/basket_recycler_view"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:clipToPadding="false"
                            android:paddingVertical="@dimen/space_xs"
                            android:paddingHorizontal="@dimen/space_s"
                            android:nestedScrollingEnabled="false"
                            android:overScrollMode="never"
                            tools:listitem="@layout/item_basket_compact"
                            tools:itemCount="3" />

                    </LinearLayout>

                </LinearLayout>

            </androidx.cardview.widget.CardView>

            <LinearLayout
                android:id="@+id/checkout_container"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_m"
                android:orientation="horizontal"
                android:visibility="gone"
                tools:visibility="visible">

                <androidx.cardview.widget.CardView
                    android:id="@+id/save_button_container"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginEnd="@dimen/space_s"
                    app:cardBackgroundColor="@android:color/transparent"
                    app:cardCornerRadius="@dimen/radius_card"
                    app:cardElevation="4dp"
                    android:visibility="gone"
                    tools:visibility="visible">

                    <Button
                        android:id="@+id/save_button"
                        android:layout_width="match_parent"
                        android:layout_height="@dimen/top_bar_height"
                        android:background="@drawable/bg_save_button"
                        android:text="@string/item_selection_save_button"
                        android:textAllCaps="false"
                        android:textAppearance="@style/Text.Button"
                        android:textColor="@color/color_bg_white" />

                </androidx.cardview.widget.CardView>

                <androidx.cardview.widget.CardView
                    android:id="@+id/charge_button_container"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    app:cardBackgroundColor="@android:color/transparent"
                    app:cardCornerRadius="@dimen/radius_card"
                    app:cardElevation="8dp">

                    <Button
                        android:id="@+id/checkout_button"
                        android:layout_width="match_parent"
                        android:layout_height="@dimen/top_bar_height"
                        android:background="@drawable/bg_checkout_button"
                        android:text="@string/item_selection_charge_button_default"
                        android:textAllCaps="false"
                        android:textAppearance="@style/Text.Button"
                        android:textColor="@color/color_bg_white"
                        tools:text="Charge" />

                </androidx.cardview.widget.CardView>

            </LinearLayout>

        </LinearLayout>

        <!-- Hidden count view for compatibility -->
        <TextView
            android:id="@+id/basket_count"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:visibility="gone" />

    </FrameLayout>

    <!-- Animated Empty State (Full Screen - shown when no items in catalog) -->
    <include
        android:id="@+id/animated_empty_state"
        layout="@layout/layout_empty_state_items"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="visible" />

</androidx.coordinatorlayout.widget.CoordinatorLayout>
