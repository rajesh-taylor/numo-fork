<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/empty_state_container"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/empty_state_background"
    android:clipChildren="false"
    android:clipToPadding="false">

    <!-- Main Content -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:clipChildren="false"
        android:clipToPadding="false">

        <!-- Spacer for navigation area -->
        <View
            android:layout_width="match_parent"
            android:layout_height="@dimen/top_bar_height" />

        <!-- Animated Chip Ribbon Area -->
        <FrameLayout
            android:id="@+id/ribbon_container"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:clipChildren="true"
            android:clipToPadding="false">

            <!-- Container for floating chips animation -->
            <FrameLayout
                android:id="@+id/ribbon_rows_wrapper"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:clipChildren="true"
                android:clipToPadding="false" />
            
            <!-- Chips are added programmatically by EmptyStateAnimator -->

            <!-- Gradient Fade at Bottom -->
            <View
                android:layout_width="match_parent"
                android:layout_height="100dp"
                android:layout_gravity="bottom"
                android:background="@drawable/bg_empty_state_fade" />

            <!-- Gradient Fade at Top -->
            <View
                android:layout_width="match_parent"
                android:layout_height="100dp"
                android:layout_gravity="top"
                android:background="@drawable/bg_empty_state_fade_top" />

        </FrameLayout>

        <!-- Content Area -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center_horizontal"
            android:paddingHorizontal="@dimen/margin_screen_horizontal"
            android:paddingBottom="@dimen/space_3xl"
            android:background="@color/empty_state_background">

            <!-- Main Heading -->
            <TextView
                android:id="@+id/empty_state_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/empty_state_items_title"
                android:textAppearance="@style/Text.DisplayLarge"
                android:textColor="@color/empty_state_title"
                android:gravity="center"
                android:lineSpacingMultiplier="1.1" />

            <!-- Subheading -->
            <TextView
                android:id="@+id/empty_state_subtitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_m"
                android:text="@string/empty_state_items_subtitle"
                android:textAppearance="@style/Text.Body"
                android:textColor="@color/empty_state_subtitle"
                android:gravity="center"
                android:lineSpacingMultiplier="1.3"
                android:paddingHorizontal="@dimen/space_l" />

            <!-- Primary Button - Add Item -->
            <Button
                android:id="@+id/empty_state_add_button"
                style="@style/Widget.Numo.Button.EmptyState.Primary"
                android:layout_width="match_parent"
                android:layout_height="@dimen/button_height"
                android:layout_marginTop="@dimen/space_xl"
                android:text="@string/empty_state_items_add_button" />

            <!-- Secondary Button - Import from CSV -->
            <TextView
                android:id="@+id/empty_state_import_button"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_l"
                android:paddingVertical="@dimen/space_m"
                android:paddingHorizontal="@dimen/space_l"
                android:text="@string/empty_state_items_import_button"
                android:textAppearance="@style/Text.Button"
                android:textColor="@color/empty_state_button_secondary_text"
                android:background="?attr/selectableItemBackgroundBorderless" />

        </LinearLayout>

    </LinearLayout>

    <!-- Navigation Button Container (Top Left) -->
    <FrameLayout
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_gravity="top|start"
        android:layout_marginTop="@dimen/space_s"
        android:layout_marginStart="@dimen/space_s"
        android:elevation="@dimen/elevation_sheet">
        
        <!-- Back Arrow (shown when from Settings → Items) -->
        <ImageButton
            android:id="@+id/empty_state_back_button"
            android:layout_width="@dimen/icon_size_large"
            android:layout_height="@dimen/icon_size_large"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/common_back"
            android:padding="@dimen/space_m"
            android:src="@drawable/ic_chevron_back"
            android:visibility="gone"
            app:tint="@color/empty_state_close_icon" />

        <!-- Close Button (shown when from Home → Items) -->
        <ImageButton
            android:id="@+id/empty_state_close_button"
            android:layout_width="@dimen/icon_size_large"
            android:layout_height="@dimen/icon_size_large"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/common_close"
            android:padding="@dimen/space_m"
            android:src="@drawable/ic_close"
            android:visibility="visible"
            app:tint="@color/empty_state_close_icon" />

    </FrameLayout>

</FrameLayout>

