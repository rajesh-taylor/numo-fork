<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="@dimen/space_m"
    app:cardCornerRadius="@dimen/radius_card"
    app:cardElevation="0dp"
    app:strokeWidth="1dp"
    app:strokeColor="@color/color_divider"
    app:cardBackgroundColor="@color/color_bg_white">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="@dimen/space_l">

        <!-- Header Row: Name + Date -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <!-- Paid badge -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/basket_archive_paid_badge"
                android:textAppearance="@style/Text.Badge"
                android:textColor="@color/color_bg_white"
                android:paddingHorizontal="@dimen/space_s"
                android:paddingVertical="2dp"
                android:background="@drawable/bg_badge_success"
                android:layout_marginEnd="@dimen/space_s" />

            <TextView
                android:id="@+id/basket_name"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textAppearance="@style/Text.RowTitle"
                android:ellipsize="end"
                android:maxLines="1"
                tools:text="Table 5" />

            <ImageButton
                android:id="@+id/delete_button"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:padding="8dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="@string/basket_archive_delete"
                android:src="@drawable/ic_trash"
                app:tint="@color/color_text_tertiary" />

        </LinearLayout>

        <!-- Date -->
        <TextView
            android:id="@+id/basket_date"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:textAppearance="@style/Text.Caption"
            tools:text="Mar 15, 2024 at 2:30 PM" />

        <!-- Divider -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginVertical="@dimen/space_m"
            android:background="@color/color_divider" />

        <!-- Items Summary -->
        <TextView
            android:id="@+id/basket_items_summary"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textAppearance="@style/Text.Body"
            android:textColor="@color/color_text_secondary"
            android:lineSpacingMultiplier="1.2"
            tools:text="2 × Coffee, 1 × Sandwich + 1 more" />

        <!-- Total + Item Count Row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_m"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/basket_total"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textAppearance="@style/Text.Subtitle"
                tools:text="$12.50" />

            <TextView
                android:id="@+id/basket_item_count"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textAppearance="@style/Text.Caption"
                tools:text="4 items" />

        </LinearLayout>

        <!-- View Payment Button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/view_payment_button"
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:layout_marginTop="@dimen/space_m"
            android:text="@string/basket_archive_view_payment"
            android:textAppearance="@style/Text.BodyBold"
            android:textColor="@color/color_accent_blue"
            app:backgroundTint="@color/color_bg_secondary"
            app:cornerRadius="@dimen/radius_m"
            app:rippleColor="@color/color_accent_blue"
            app:strokeWidth="0dp"
            style="@style/Widget.MaterialComponents.Button.UnelevatedButton" />

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>
