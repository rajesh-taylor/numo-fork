<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/payment_request_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/color_bg_white">

    <!-- Top Bar -->
    <ImageButton
        android:id="@+id/close_button"
        android:layout_width="@dimen/icon_size_large"
        android:layout_height="@dimen/icon_size_large"
        android:layout_marginStart="@dimen/space_l"
        android:layout_marginTop="@dimen/space_l"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:src="@drawable/ic_close"
        android:contentDescription="@string/payment_request_close_content_description"
        app:tint="@color/color_text_primary"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <ImageButton
        android:id="@+id/share_button"
        android:layout_width="@dimen/icon_size_large"
        android:layout_height="@dimen/icon_size_large"
        android:layout_marginEnd="@dimen/space_l"
        android:layout_marginTop="@dimen/space_l"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:src="@drawable/ic_share"
        android:contentDescription="@string/payment_request_share_content_description"
        app:tint="@color/color_text_primary"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- Pay Label -->
    <TextView
        android:id="@+id/pay_label"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="@dimen/space_xs"
        android:text="@string/payment_request_pay_label"
        android:textColor="@color/color_text_secondary"
        android:textSize="18sp"
        android:textStyle="normal"
        app:layout_constraintBottom_toTopOf="@id/large_amount_display"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/close_button" />

    <!-- Large Amount Display -->
    <TextView
        android:id="@+id/large_amount_display"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="@dimen/space_xs"
        android:text="₿ 0"
        android:textColor="@color/color_text_primary"
        android:textSize="48sp"
        android:textStyle="bold"
        android:maxLines="1"
        app:autoSizeTextType="uniform"
        app:autoSizeMinTextSize="24sp"
        app:autoSizeMaxTextSize="48sp"
        app:autoSizeStepGranularity="2sp"
        app:layout_constraintBottom_toTopOf="@id/converted_amount_display"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/pay_label" />

    <!-- Converted Amount Display -->
    <TextView
        android:id="@+id/converted_amount_display"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="@dimen/space_xl"
        android:text=""
        android:textColor="@color/color_text_secondary"
        android:textSize="16sp"
        android:textStyle="normal"
        android:visibility="gone"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/large_amount_display" />

    <!-- Tip Info Text (shown when tip was added) -->
    <TextView
        android:id="@+id/tip_info_text"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/space_s"
        android:text=""
        android:textColor="@color/color_success_green"
        android:textSize="14sp"
        android:textStyle="normal"
        android:visibility="gone"
        app:layout_constraintBottom_toTopOf="@id/qr_card"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/converted_amount_display" />

    <!-- QR Code Card -->
    <FrameLayout
        android:id="@+id/qr_card"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginTop="@dimen/space_l"
        android:layout_marginHorizontal="@dimen/space_2xl"
        android:background="@drawable/bg_qr_card"
        app:layout_constraintDimensionRatio="1:1"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tip_info_text"
        app:layout_constraintBottom_toTopOf="@id/icons_container"
        app:layout_constraintVertical_chainStyle="packed"
        app:layout_constraintVertical_bias="0.5">

        <FrameLayout
            android:id="@+id/lightning_qr_container"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:padding="@dimen/space_xl">

            <ImageView
                android:id="@+id/lightning_qr"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:adjustViewBounds="true"
                android:scaleType="fitCenter"
                android:visibility="invisible" />

            <!-- Loading spinner for Lightning invoice generation -->
            <ProgressBar
                android:id="@+id/lightning_loading_spinner"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_gravity="center"
                android:indeterminate="true"
                android:visibility="visible" />

            <!-- Center Logo Overlay for Lightning -->
            <androidx.cardview.widget.CardView
                android:id="@+id/lightning_logo_card"
                android:layout_width="@dimen/icon_size_large"
                android:layout_height="@dimen/icon_size_large"
                android:layout_gravity="center"
                app:cardBackgroundColor="@color/color_bg_white"
                app:cardCornerRadius="@dimen/radius_m"
                app:cardElevation="0dp"
                android:visibility="gone">

                <ImageView
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:layout_gravity="center"
                    android:src="@drawable/ic_lightning_black"
                    app:tint="@color/color_text_primary" />
            </androidx.cardview.widget.CardView>
        </FrameLayout>

        <FrameLayout
            android:id="@+id/cashu_qr_container"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:padding="@dimen/space_xl"
            android:visibility="visible">

            <ImageView
                android:id="@+id/payment_request_qr"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:adjustViewBounds="true"
                android:scaleType="fitCenter"
                android:visibility="invisible" />
                
            <!-- Loading spinner for Cashu payment request generation -->
            <ProgressBar
                android:id="@+id/cashu_loading_spinner"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_gravity="center"
                android:indeterminate="true"
                android:visibility="visible" />

            <!-- Center Logo Overlay for Cashu -->
            <androidx.cardview.widget.CardView
                android:layout_width="@dimen/icon_size_large"
                android:layout_height="@dimen/icon_size_large"
                android:layout_gravity="center"
                app:cardBackgroundColor="@color/color_bg_white"
                app:cardCornerRadius="@dimen/radius_m"
                app:cardElevation="0dp">

                <ImageView
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:layout_gravity="center"
                    android:src="@drawable/cashu" />
            </androidx.cardview.widget.CardView>
        </FrameLayout>
        
        <FrameLayout
            android:id="@+id/unified_qr_container"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:padding="@dimen/space_xl"
            android:visibility="invisible">

            <ImageView
                android:id="@+id/unified_qr"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:adjustViewBounds="true"
                android:scaleType="fitCenter"
                android:visibility="invisible" />

            <!-- Loading spinner for Unified QR generation (waiting for both Cashu and Lightning) -->
            <ProgressBar
                android:id="@+id/unified_loading_spinner"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_gravity="center"
                android:indeterminate="true"
                android:visibility="visible" />
        </FrameLayout>
    </FrameLayout>


    <!-- Icons and Instruction -->
    <LinearLayout
        android:id="@+id/icons_container"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/space_l"
        android:orientation="horizontal"
        android:gravity="center"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/qr_card">

        <ImageView
            android:layout_width="@dimen/icon_size_small"
            android:layout_height="@dimen/icon_size_small"
            android:src="@drawable/contactless"
            android:rotation="270"
            app:tint="@color/color_text_primary" />

        <TextView
            android:id="@+id/instruction_text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/space_m"
            android:text="@string/payment_request_instruction_scan_or_tap"
            android:textColor="@color/color_text_primary"
            android:textSize="24sp"
            android:textStyle="bold"
            android:gravity="center" />
    </LinearLayout>

    <!-- Status Text (Hidden) -->
    <TextView
        android:id="@+id/payment_status_text"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/space_s"
        android:text="@string/payment_request_status_waiting_for_payment"
        android:textColor="@color/color_text_secondary"
        android:textSize="14sp"
        android:visibility="gone"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/icons_container" />


    <!-- Lightning / Cashu / Unified Switcher (tabs-style) now at the bottom -->
    <LinearLayout
        android:id="@+id/lightning_cashu_switch_container"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/space_m"
        android:layout_marginBottom="@dimen/space_xl"
        android:orientation="horizontal"
        android:background="@drawable/bg_button_secondary_pill"
        android:padding="5dp"
        app:layout_constraintTop_toBottomOf="@id/payment_status_text"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- Unified Tab -->
        <LinearLayout
            android:id="@+id/unified_tab"
            android:layout_width="wrap_content"
            android:layout_height="42dp"
            android:gravity="center"
            android:paddingHorizontal="@dimen/row_padding_vertical"
            android:orientation="horizontal"
            android:background="@drawable/bg_button_primary_green">

            <TextView
                android:id="@+id/unified_tab_icon"
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:text="U"
                android:textSize="18sp"
                android:textStyle="bold"
                android:gravity="center"
                android:textColor="@color/color_bg_white" />

            <TextView
                android:id="@+id/unified_tab_text"
                android:layout_width="100dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="0dp"
                android:text="@string/payment_request_tab_unified"
                android:textSize="18sp"
                android:textStyle="bold"
                android:gravity="center"
                android:textColor="@color/color_bg_white" />
        </LinearLayout>

        <!-- Cashu Tab -->
        <LinearLayout
            android:id="@+id/cashu_tab"
            android:layout_width="wrap_content"
            android:layout_height="42dp"
            android:gravity="center"
            android:paddingHorizontal="@dimen/row_padding_vertical"
            android:orientation="horizontal"
            android:background="@android:color/transparent">

            <ImageView
                android:id="@+id/cashu_tab_icon"
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@drawable/cashu"
                app:tint="@color/color_text_secondary" />

            <TextView
                android:id="@+id/cashu_tab_text"
                android:layout_width="100dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="0dp"
                android:text="Cashu"
                android:textSize="18sp"
                android:textStyle="bold"
                android:gravity="center"
                android:textColor="@color/color_text_secondary"
                android:visibility="gone" />
        </LinearLayout>

        <!-- Lightning Tab -->
        <LinearLayout
            android:id="@+id/lightning_tab"
            android:layout_width="wrap_content"
            android:layout_height="42dp"
            android:gravity="center"
            android:paddingHorizontal="@dimen/row_padding_vertical"
            android:orientation="horizontal"
            android:background="@android:color/transparent">

            <ImageView
                android:id="@+id/lightning_tab_icon"
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@drawable/ic_lightning_black"
                app:tint="@color/color_text_secondary" />

            <TextView
                android:id="@+id/lightning_tab_text"
                android:layout_width="100dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="0dp"
                android:text="Lightning"
                android:textSize="18sp"
                android:textStyle="bold"
                android:gravity="center"
                android:textColor="@color/color_text_secondary"
                android:visibility="gone" />
        </LinearLayout>
    </LinearLayout>


    <!-- NFC Animation Overlay (Native View) - ONLY for NFC payments -->
    <FrameLayout
        android:id="@+id/nfc_animation_container"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/color_nfc_idle"
        android:clickable="true"
        android:focusable="true"
        android:fitsSystemWindows="false"
        android:visibility="gone"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <com.electricdreams.numo.ui.animation.NfcPaymentAnimationView
            android:id="@+id/nfc_animation_view"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@android:color/transparent" />

        <TextView
            android:id="@+id/animation_result_amount"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal|center_vertical"
            android:gravity="center"
            android:textAlignment="center"
            android:translationY="-180dp"
            android:textColor="@android:color/white"
            android:textSize="56sp"
            android:textStyle="bold"
            android:visibility="gone" />

        <TextView
            android:id="@+id/animation_result_label"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal|center_vertical"
            android:layout_marginStart="@dimen/space_2xl"
            android:layout_marginEnd="@dimen/space_2xl"
            android:gravity="center"
            android:maxLines="3"
            android:textAlignment="center"
            android:translationY="-120dp"
            android:textColor="@android:color/white"
            android:textSize="18sp"
            android:textStyle="bold"
            android:visibility="gone" />

        <!-- Result action buttons appear after animation completes -->
        <LinearLayout
            android:id="@+id/animation_actions_container"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom|center_horizontal"
            android:layout_marginStart="@dimen/space_xl"
            android:layout_marginEnd="@dimen/space_xl"
            android:layout_marginBottom="@dimen/space_3xl"
            android:gravity="center_horizontal"
            android:orientation="vertical"
            android:visibility="gone">

            <TextView
                android:id="@+id/animation_view_details_button"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:background="?attr/selectableItemBackground"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center"
                android:text="@string/payment_received_button_view_details"
                android:textColor="@android:color/white"
                android:textSize="16sp"
                android:textStyle="bold"
                android:visibility="gone" />

            <TextView
                android:id="@+id/animation_close_button"
                android:layout_width="match_parent"
                android:layout_height="@dimen/button_height"
                android:layout_marginTop="@dimen/space_m"
                android:background="@drawable/bg_button_black"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackground"
                android:gravity="center"
                android:text="@string/payment_request_animation_close"
                android:textColor="@color/color_text_on_dark"
                android:textSize="18sp"
                android:textStyle="bold" />
        </LinearLayout>
    </FrameLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
