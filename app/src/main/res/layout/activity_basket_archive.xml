<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/color_bg_white">

    <!-- Top Bar -->
    <com.electricdreams.numo.ui.components.NumoTopBar
        android:id="@+id/top_bar"
        android:layout_width="match_parent"
        android:layout_height="@dimen/top_bar_height"
        app:topBarTitle="@string/basket_archive_title"
        app:topBarNavContentDescription="@string/basket_archive_back" />

    <!-- Content -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:background="@color/color_bg_light">

        <!-- Archive List -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/archive_recycler_view"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:clipToPadding="false"
            android:paddingTop="@dimen/space_m"
            android:paddingBottom="@dimen/space_xl"
            android:paddingHorizontal="@dimen/space_l"
            tools:listitem="@layout/item_basket_archive" />

        <!-- Empty State -->
        <LinearLayout
            android:id="@+id/empty_view"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:orientation="vertical"
            android:padding="@dimen/space_2xl"
            android:visibility="gone"
            tools:visibility="visible">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/basket_archive_empty_title"
                android:textAppearance="@style/Text.Subtitle"
                android:paddingBottom="@dimen/space_s" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/basket_archive_empty_subtitle"
                android:textAppearance="@style/Text.Body"
                android:gravity="center"
                android:paddingHorizontal="@dimen/space_l" />

        </LinearLayout>

    </FrameLayout>

</LinearLayout>
