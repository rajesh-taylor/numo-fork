<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/bg_dialog_rounded">

    <!-- ═══════════════════════════════════════════════════════════════════════ -->
    <!-- HEADER ROW - Close button + Title                                        -->
    <!-- ═══════════════════════════════════════════════════════════════════════ -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="@dimen/top_bar_height"
        android:paddingHorizontal="@dimen/space_xs">

        <!-- Close X Button (top-left) -->
        <ImageButton
            android:id="@+id/close_button"
            android:layout_width="@dimen/icon_size_large"
            android:layout_height="@dimen/icon_size_large"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/common_close"
            android:padding="@dimen/space_m"
            android:src="@drawable/ic_close"
            app:tint="@color/color_text_secondary"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent" />

        <!-- Title (centered) -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/basket_archive_detail_title"
            style="@style/Text.Title"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- Divider -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/color_divider" />

    <!-- ═══════════════════════════════════════════════════════════════════════ -->
    <!-- SUMMARY SECTION                                                          -->
    <!-- ═══════════════════════════════════════════════════════════════════════ -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="@dimen/margin_screen_horizontal"
        android:gravity="center_horizontal">

        <!-- Order Name with Badge -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/basket_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textAppearance="@style/Text.Subtitle"
                tools:text="Table 5" />

            <!-- PAID Badge -->
            <TextView
                android:id="@+id/paid_badge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/space_s"
                android:paddingHorizontal="@dimen/space_s"
                android:paddingVertical="3dp"
                android:text="@string/basket_archive_paid_badge"
                android:textAppearance="@style/Text.Badge"
                android:textColor="@android:color/white"
                android:letterSpacing="0.03"
                android:background="@drawable/bg_badge_success_pill" />

        </LinearLayout>

        <!-- Date/Time -->
        <TextView
            android:id="@+id/basket_date"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_xs"
            android:textAppearance="@style/Text.RowSubtitle"
            tools:text="Nov 26, 2024 at 2:30 PM" />

        <!-- Total Amount (Large) -->
        <TextView
            android:id="@+id/basket_total"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_l"
            android:textAppearance="@style/Text.DisplayXL"
            android:textSize="34sp"
            android:letterSpacing="-0.02"
            tools:text="$74.97" />

    </LinearLayout>

    <!-- ═══════════════════════════════════════════════════════════════════════ -->
    <!-- ITEMS CARD                                                               -->
    <!-- ═══════════════════════════════════════════════════════════════════════ -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="@dimen/space_l"
        android:orientation="vertical"
        android:background="@drawable/bg_rounded_card_large"
        android:clipChildren="true"
        android:clipToPadding="true">

        <!-- Section Header -->
        <TextView
            android:id="@+id/items_header"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingHorizontal="@dimen/space_l"
            android:paddingTop="@dimen/row_padding_vertical"
            android:paddingBottom="@dimen/space_m"
            android:textAppearance="@style/Text.Overline"
            android:textAllCaps="false"
            android:letterSpacing="0.06"
            tools:text="3 ITEMS" />

        <!-- Divider -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginHorizontal="@dimen/space_l"
            android:background="@color/color_divider" />

        <!-- Items ScrollView -->
        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:scrollbars="none"
            android:fillViewport="true">

            <LinearLayout
                android:id="@+id/items_container"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingVertical="@dimen/space_s" />

        </ScrollView>

    </LinearLayout>

    <!-- ═══════════════════════════════════════════════════════════════════════ -->
    <!-- ACTION BUTTON                                                            -->
    <!-- ═══════════════════════════════════════════════════════════════════════ -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/view_payment_button"
        style="@style/Widget.Numo.Button.Dialog.Confirm"
        android:layout_width="match_parent"
        android:layout_height="@dimen/top_bar_height"
        android:layout_marginTop="@dimen/margin_screen_horizontal"
        android:layout_marginHorizontal="@dimen/margin_screen_horizontal"
        android:layout_marginBottom="@dimen/margin_screen_horizontal"
        android:text="@string/basket_archive_detail_view_payment"
        app:icon="@drawable/ic_receipt"
        app:iconTint="@color/color_bg_white"
        app:iconPadding="8dp"
        app:iconGravity="textStart" />

</LinearLayout>
