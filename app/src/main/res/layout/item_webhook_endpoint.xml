<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_row_ripple"
    android:clickable="true"
    android:focusable="true"
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:paddingVertical="@dimen/row_padding_vertical"
    android:paddingHorizontal="@dimen/margin_screen_horizontal">

    <ImageView
        android:importantForAccessibility="no"
        android:layout_width="@dimen/icon_size_small"
        android:layout_height="@dimen/icon_size_small"
        android:layout_marginEnd="@dimen/row_icon_gap"
        android:src="@drawable/ic_link"
        app:tint="@color/color_icon_secondary" />

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/endpoint_url_text"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:ellipsize="end"
            android:maxLines="1"
            android:textAppearance="@style/Text.RowTitle" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="2dp">

            <ImageView
                android:importantForAccessibility="no"
                android:id="@+id/endpoint_status_dot"
                android:layout_width="8dp"
                android:layout_height="8dp"
                android:layout_marginEnd="@dimen/space_s"
                android:src="@drawable/bg_status_dot"
                app:tint="@color/color_text_tertiary" />

            <TextView
                android:id="@+id/endpoint_auth_status_text"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/webhook_settings_auth_not_set"
                android:textAppearance="@style/Text.RowSubtitle" />
        </LinearLayout>
    </LinearLayout>

    <ImageButton
        android:id="@+id/edit_auth_button"
        android:layout_width="@dimen/icon_size_medium"
        android:layout_height="@dimen/icon_size_medium"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:contentDescription="@string/webhook_settings_edit_auth_key"
        android:padding="@dimen/space_s"
        android:src="@drawable/ic_key"
        app:tint="@color/color_text_tertiary" />

    <ImageButton
        android:id="@+id/delete_button"
        android:layout_width="@dimen/icon_size_medium"
        android:layout_height="@dimen/icon_size_medium"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:contentDescription="@string/webhook_settings_delete_endpoint"
        android:padding="@dimen/space_s"
        android:src="@drawable/ic_delete"
        app:tint="@color/color_text_tertiary" />

</LinearLayout>
