<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/color_bg_white">

    <!-- Top App Bar -->
    <com.electricdreams.numo.ui.components.NumoTopBar
        android:id="@+id/top_bar"
        android:layout_width="match_parent"
        android:layout_height="@dimen/top_bar_height"
        app:topBarTitle="@string/transaction_detail_toolbar_title"
        app:topBarNavContentDescription="@string/transaction_detail_toolbar_back"
        app:topBarActionIcon="@drawable/ic_more_vert"
        app:topBarActionContentDescription="@string/transaction_detail_overflow_menu"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- Scrollable Content -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:fillViewport="true"
        app:layout_constraintTop_toBottomOf="@id/top_bar"
        app:layout_constraintBottom_toBottomOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingTop="@dimen/space_2xl"
            android:paddingBottom="@dimen/space_2xl">

            <!-- Large Fiat Amount Display -->
            <TextView
                android:id="@+id/detail_amount"
                style="@style/Text.DisplayAmount"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:textColor="@color/color_text_primary"
                tools:text="$20.00" />

            <!-- Secondary amount (sat equivalent for fiat entries, or fiat equivalent for sat entries) -->
            <TextView
                android:id="@+id/detail_amount_subtitle"
                style="@style/Text.AmountSubtitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_xs"
                tools:text="₿27,849" />

            <!-- Fiat equivalent (shown below sat amount on sat-entry transactions) -->
            <TextView
                android:id="@+id/detail_fiat_equivalent"
                style="@style/Text.AmountSubtitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_xs"
                android:visibility="gone"
                tools:text="$0.01" />

            <!-- Date/Time -->
            <TextView
                android:id="@+id/detail_date"
                style="@style/Text.Caption"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_l"
                android:gravity="center"
                tools:text="March 15, 2026 at 11:31 AM" />

            <!-- Transaction Details Section Header -->
            <TextView
                style="@style/Text.SectionHeader"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/space_xl"
                android:layout_marginEnd="@dimen/space_xl"
                android:layout_marginTop="@dimen/space_2xl"
                android:text="@string/transaction_detail_section_transaction_details" />

            <!-- Transaction Type Row -->
            <LinearLayout
                android:id="@+id/row_transaction_type"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingStart="@dimen/space_xl"
                android:paddingEnd="@dimen/space_xl"
                android:paddingTop="@dimen/space_l"
                android:paddingBottom="@dimen/space_l">

                <ImageView
                    android:layout_width="@dimen/icon_size_small"
                    android:layout_height="@dimen/icon_size_small"
                    android:src="@drawable/ic_card"
                    app:tint="@color/color_text_secondary"
                    android:contentDescription="@null" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginStart="@dimen/space_l">

                    <TextView
                        style="@style/Text.BodyBold"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/transaction_detail_payment_type_label" />

                    <TextView
                        android:id="@+id/detail_payment_type"
                        style="@style/Text.Body"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/row_subtitle_gap"
                        tools:text="Cashu" />

                </LinearLayout>

            </LinearLayout>

            <!-- Exchange Rate Row -->
            <LinearLayout
                android:id="@+id/row_exchange_rate"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingStart="@dimen/space_xl"
                android:paddingEnd="@dimen/space_xl"
                android:paddingTop="@dimen/space_l"
                android:paddingBottom="@dimen/space_l"
                android:visibility="gone">

                <ImageView
                    android:layout_width="@dimen/icon_size_small"
                    android:layout_height="@dimen/icon_size_small"
                    android:src="@drawable/ic_switch_currency"
                    app:tint="@color/color_text_secondary"
                    android:contentDescription="@null" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginStart="@dimen/space_l">

                    <TextView
                        style="@style/Text.BodyBold"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/transaction_detail_exchange_rate_label" />

                    <TextView
                        android:id="@+id/detail_exchange_rate"
                        style="@style/Text.Body"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/row_subtitle_gap"
                        tools:text="$71,833.46" />

                </LinearLayout>

            </LinearLayout>

            <!-- Mint Row -->
            <LinearLayout
                android:id="@+id/row_mint"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingStart="@dimen/space_xl"
                android:paddingEnd="@dimen/space_xl"
                android:paddingTop="@dimen/space_l"
                android:paddingBottom="@dimen/space_l">

                <ImageView
                    android:layout_width="@dimen/icon_size_small"
                    android:layout_height="@dimen/icon_size_small"
                    android:src="@drawable/ic_bank"
                    app:tint="@color/color_text_secondary"
                    android:contentDescription="@null" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginStart="@dimen/space_l">

                    <TextView
                        style="@style/Text.BodyBold"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/transaction_detail_mint_label_short" />

                    <TextView
                        android:id="@+id/detail_mint_url"
                        style="@style/Text.Body"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/row_subtitle_gap"
                        android:maxLines="2"
                        android:ellipsize="end"
                        tools:text="https://mint.minibits.cash/Bitcoin" />

                </LinearLayout>

            </LinearLayout>

            <!-- Sent To Row (withdrawals only) -->
            <LinearLayout
                android:id="@+id/row_sent_to"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingStart="@dimen/space_xl"
                android:paddingEnd="@dimen/space_xl"
                android:paddingTop="@dimen/space_l"
                android:paddingBottom="@dimen/space_l"
                android:visibility="gone">

                <ImageView
                    android:layout_width="@dimen/icon_size_small"
                    android:layout_height="@dimen/icon_size_small"
                    android:src="@drawable/ic_arrow_up_send"
                    app:tint="@color/color_text_secondary"
                    android:contentDescription="@null" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginStart="@dimen/space_l">

                    <TextView
                        style="@style/Text.BodyBold"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/transaction_detail_sent_to_label" />

                    <TextView
                        android:id="@+id/detail_sent_to"
                        style="@style/Text.Body"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/row_subtitle_gap"
                        android:maxLines="2"
                        android:ellipsize="end"
                        tools:text="erik@primal.net" />

                </LinearLayout>

                <ImageButton
                    android:id="@+id/btn_copy_destination"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:src="@drawable/ic_copy"
                    android:padding="@dimen/space_xs"
                    app:tint="@color/color_text_quaternary"
                    android:contentDescription="@string/transaction_detail_sent_to_label" />

            </LinearLayout>

            <!-- Invoice / Transaction ID Row -->
            <LinearLayout
                android:id="@+id/row_invoice"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingStart="@dimen/space_xl"
                android:paddingEnd="@dimen/space_xl"
                android:paddingTop="@dimen/space_l"
                android:paddingBottom="@dimen/space_l">

                <ImageView
                    android:layout_width="@dimen/icon_size_small"
                    android:layout_height="@dimen/icon_size_small"
                    android:src="@drawable/ic_document"
                    app:tint="@color/color_text_secondary"
                    android:contentDescription="@null" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginStart="@dimen/space_l">

                    <TextView
                        android:id="@+id/detail_invoice_label"
                        style="@style/Text.BodyBold"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/transaction_detail_invoice_label" />

                    <TextView
                        android:id="@+id/detail_invoice_value"
                        style="@style/Text.Body"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/row_subtitle_gap"
                        android:maxLines="1"
                        android:ellipsize="middle"
                        tools:text="lnbc1pvjluezpp5qqqsyq..." />

                </LinearLayout>

                <ImageButton
                    android:id="@+id/btn_copy_invoice"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:src="@drawable/ic_copy"
                    android:padding="@dimen/space_xs"
                    app:tint="@color/color_text_quaternary"
                    android:contentDescription="@string/transaction_detail_copy_invoice_hint" />

            </LinearLayout>

            <!-- Label Row (only shown if label exists) -->
            <LinearLayout
                android:id="@+id/row_label"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingStart="@dimen/space_xl"
                android:paddingEnd="@dimen/space_xl"
                android:paddingTop="@dimen/space_l"
                android:paddingBottom="@dimen/space_l"
                android:visibility="gone">

                <ImageView
                    android:layout_width="@dimen/icon_size_small"
                    android:layout_height="@dimen/icon_size_small"
                    android:src="@drawable/ic_label"
                    app:tint="@color/color_text_secondary"
                    android:contentDescription="@null" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginStart="@dimen/space_l">

                    <TextView
                        style="@style/Text.BodyBold"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/transaction_detail_label_row_title" />

                    <TextView
                        android:id="@+id/detail_label_value"
                        style="@style/Text.Body"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/row_subtitle_gap"
                        android:maxLines="2"
                        android:ellipsize="end"
                        tools:text="Coffee order" />

                </LinearLayout>

            </LinearLayout>

            <!-- Items Section Header -->
            <TextView
                android:id="@+id/items_header"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="24dp"
                android:layout_marginEnd="24dp"
                android:layout_marginTop="32dp"
                android:textSize="12sp"
                android:fontFamily="sans-serif-medium"
                android:textColor="@color/color_text_secondary"
                android:letterSpacing="0.08"
                android:text="@string/basket_receipt_items_header_single"
                android:visibility="gone"
                tools:text="3 ITEMS" />

            <!-- Items List Container -->
            <LinearLayout
                android:id="@+id/items_container"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginTop="12dp"
                android:layout_marginHorizontal="16dp"
                android:background="@drawable/bg_rounded_card_large"
                android:clipChildren="false"
                android:clipToPadding="false"
                android:visibility="gone">

                <!-- Items will be added programmatically -->

            </LinearLayout>

            <!-- Totals Section -->
            <LinearLayout
                android:id="@+id/totals_container"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginTop="20dp"
                android:layout_marginHorizontal="16dp"
                android:background="@drawable/bg_rounded_card_large"
                android:padding="16dp"
                android:visibility="gone">

                <!-- Subtotal Row (Net) -->
                <LinearLayout
                    android:id="@+id/subtotal_row"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:visibility="gone"
                    android:gravity="center_vertical">

                    <TextView
                        android:id="@+id/subtotal_label"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:textSize="15sp"
                        android:textColor="@color/color_text_secondary"
                        android:text="@string/basket_receipt_subtotal_label" />

                    <TextView
                        android:id="@+id/subtotal_value"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="15sp"
                        android:textColor="@color/color_text_secondary"
                        tools:text="$62.48" />

                </LinearLayout>

                <!-- VAT Breakdown Container -->
                <LinearLayout
                    android:id="@+id/vat_breakdown_container"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_marginTop="10dp">

                    <!-- VAT rows will be added programmatically -->

                </LinearLayout>

                <!-- Sats Items Row (for mixed baskets) -->
                <LinearLayout
                    android:id="@+id/sats_items_row"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_marginTop="10dp"
                    android:visibility="gone">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:textSize="15sp"
                            android:textColor="@color/color_text_secondary"
                            android:text="@string/basket_receipt_bitcoin_items_label" />

                        <TextView
                            android:id="@+id/sats_items_value"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textSize="15sp"
                            android:textColor="@color/color_text_secondary"
                            tools:text="₿50,000" />

                    </LinearLayout>

                    <TextView
                        android:id="@+id/sats_items_equiv"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:textSize="13sp"
                        android:textColor="@color/color_text_tertiary"
                        android:gravity="end"
                        android:visibility="gone"
                        tools:text="≈ $50.00" />

                </LinearLayout>

                <!-- Divider before total -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginTop="14dp"
                    android:layout_marginBottom="14dp"
                    android:background="@color/color_divider" />

                <!-- Final Total Row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <TextView
                        android:id="@+id/final_total_label"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:textSize="17sp"
                        android:textColor="@color/color_text_primary"
                        android:fontFamily="sans-serif-medium"
                        android:text="@string/basket_receipt_total_label" />

                    <TextView
                        android:id="@+id/final_total_value"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="20sp"
                        android:textColor="@color/color_text_primary"
                        android:fontFamily="sans-serif-medium"
                        tools:text="$74.97" />

                </LinearLayout>

                <!-- Sats Equivalent (if applicable) -->
                <TextView
                    android:id="@+id/sats_equivalent"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:textSize="14sp"
                    android:textColor="@color/color_text_tertiary"
                    android:gravity="end"
                    android:visibility="gone"
                    tools:visibility="visible"
                    tools:text="≈ ₿74,970" />

            </LinearLayout>


            <!-- Print Receipt Button -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_print_receipt"
                style="@style/Widget.Numo.Button.Dialog.Confirm"
                android:layout_width="match_parent"
                android:layout_height="@dimen/button_height"
                android:layout_marginStart="@dimen/space_xl"
                android:layout_marginEnd="@dimen/space_xl"
                android:layout_marginTop="@dimen/space_xl"
                android:text="@string/transaction_detail_print_receipt" />

        </LinearLayout>

    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>
