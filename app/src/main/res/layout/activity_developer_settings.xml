<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/color_bg_white">

    <!-- Top App Bar -->
    <com.electricdreams.numo.ui.components.NumoTopBar
        android:id="@+id/top_bar"
        android:layout_width="match_parent"
        android:layout_height="@dimen/top_bar_height"
        app:topBarTitle="@string/developer_settings_title"
        app:topBarNavIcon="@drawable/ic_close"
        app:layout_constraintTop_toTopOf="parent" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@id/top_bar">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="@dimen/space_2xl">

            <!-- Debugging Section -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingHorizontal="@dimen/settings_horizontal_padding"
                android:paddingTop="@dimen/space_l"
                android:paddingBottom="@dimen/space_s"
                android:text="@string/developer_settings_section_debugging"
                style="@style/Text.SectionHeader" />

            <!-- Restart Onboarding -->
            <LinearLayout
                android:id="@+id/restart_onboarding_item"
                android:layout_width="match_parent"
                android:layout_height="72dp"
                android:background="?attr/selectableItemBackground"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingHorizontal="@dimen/settings_horizontal_padding">

                <ImageView
                    android:importantForAccessibility="no"
                    android:layout_width="@dimen/icon_size_small"
                    android:layout_height="@dimen/icon_size_small"
                    android:layout_marginEnd="@dimen/space_l"
                    android:src="@drawable/ic_restore"
                    app:tint="@color/color_icon_secondary" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/developer_settings_restart_onboarding_title"
                        android:textAppearance="@style/Text.RowTitle" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/developer_settings_restart_onboarding_subtitle"
                        android:textAppearance="@style/Text.RowSubtitle"
                        android:layout_marginTop="2dp" />
                </LinearLayout>

                <ImageView
                    android:importantForAccessibility="no"
                    android:layout_width="@dimen/icon_size_small"
                    android:layout_height="@dimen/icon_size_small"
                    android:src="@drawable/ic_chevron_forward"
                    app:tint="@color/color_icon_secondary" />
            </LinearLayout>

            <!-- Delay Lightning Invoice -->
            <LinearLayout
                android:id="@+id/delay_lightning_invoice_item"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:minHeight="72dp"
                android:background="?attr/selectableItemBackground"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingHorizontal="@dimen/settings_horizontal_padding"
                android:paddingVertical="@dimen/space_m">

                <ImageView
                    android:layout_width="@dimen/icon_size_small"
                    android:layout_height="@dimen/icon_size_small"
                    android:layout_marginEnd="@dimen/space_l"
                    android:src="@drawable/ic_lightning_bolt"
                    app:tint="@color/color_icon_secondary"
                    android:contentDescription="@null" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginEnd="@dimen/space_l">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/developer_settings_lightning_invoice_title"
                        android:textAppearance="@style/Text.RowTitle" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/developer_settings_lightning_invoice_subtitle"
                        android:textAppearance="@style/Text.RowSubtitle"
                        android:layout_marginTop="2dp" />
                </LinearLayout>

                <com.google.android.material.switchmaterial.SwitchMaterial
                    android:id="@+id/delay_lightning_invoice_switch"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content" />
            </LinearLayout>

            <!-- Error Logs -->
            <LinearLayout
                android:id="@+id/error_logs_item"
                android:layout_width="match_parent"
                android:layout_height="72dp"
                android:background="?attr/selectableItemBackground"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingHorizontal="@dimen/settings_horizontal_padding">

                <ImageView
                    android:importantForAccessibility="no"
                    android:layout_width="@dimen/icon_size_small"
                    android:layout_height="@dimen/icon_size_small"
                    android:layout_marginEnd="@dimen/space_l"
                    android:src="@drawable/ic_warning"
                    app:tint="@color/color_icon_secondary" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/developer_error_logs_title"
                        android:textAppearance="@style/Text.RowTitle" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/developer_error_logs_subtitle"
                        android:textAppearance="@style/Text.RowSubtitle"
                        android:layout_marginTop="2dp" />
                </LinearLayout>

                <ImageView
                    android:importantForAccessibility="no"
                    android:layout_width="@dimen/icon_size_small"
                    android:layout_height="@dimen/icon_size_small"
                    android:src="@drawable/ic_chevron_forward"
                    app:tint="@color/color_icon_secondary" />
            </LinearLayout>

            <!-- Warning Text -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingHorizontal="@dimen/settings_horizontal_padding"
                android:paddingTop="@dimen/space_l"
                android:text="@string/developer_settings_warning"
                android:textAppearance="@style/Text.Caption"
                android:textColor="@color/color_warning"
                android:background="@color/color_bg_secondary"
                android:padding="@dimen/space_l"
                android:layout_marginHorizontal="@dimen/space_l"
                android:layout_marginTop="@dimen/space_l" />

        </LinearLayout>
    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>
