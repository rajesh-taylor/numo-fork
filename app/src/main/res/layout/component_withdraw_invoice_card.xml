<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="@dimen/margin_screen_horizontal">

    <!-- Lightning Invoice Label -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="@dimen/space_m"
        android:text="@string/withdraw_invoice_card_title"
        style="@style/Text.RowTitle" />

    <!-- Input Field -->
    <com.google.android.material.textfield.TextInputLayout
        style="@style/Widget.Numo.TextInputLayout.OutlinedBox"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/invoice_input"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:fontFamily="sans-serif"
            android:hint="@string/withdraw_invoice_placeholder"
            android:inputType="textMultiLine"
            android:maxLines="4"
            android:minHeight="80dp"
            android:gravity="top"
            android:textAppearance="@style/Text.Body"
            android:textColor="@color/color_text_primary"
            android:textColorHint="@color/color_text_tertiary" />

    </com.google.android.material.textfield.TextInputLayout>

    <!-- Helper Text -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/space_s"
        android:alpha="0.7"
        android:text="@string/withdraw_invoice_helper"
        android:textAppearance="@style/Text.Helper" />

    <!-- Continue Button -->
    <Button
        android:id="@+id/continue_button"
        style="@style/Widget.Button.Primary.Green"
        android:layout_width="match_parent"
        android:layout_height="@dimen/button_height"
        android:layout_marginTop="@dimen/space_l"
        android:enabled="false"
        android:text="@string/withdraw_continue_button"
        android:textAllCaps="false"
        android:textSize="17sp" />

    <!-- Scan Invoice Button -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/scan_button"
        android:layout_width="match_parent"
        android:layout_height="@dimen/button_height"
        android:layout_marginTop="@dimen/space_m"
        android:insetTop="0dp"
        android:insetBottom="0dp"
        android:text="@string/withdraw_scan_invoice_button"
        android:textAllCaps="false"
        android:textSize="17sp"
        android:textColor="@color/color_text_primary"
        android:fontFamily="sans-serif-medium"
        android:stateListAnimator="@null"
        app:backgroundTint="@color/color_bg_white"
        app:strokeColor="@color/color_chip_border"
        app:strokeWidth="1dp"
        app:cornerRadius="@dimen/radius_pill"
        app:elevation="0dp"
        app:icon="@drawable/ic_qr_scan"
        app:iconGravity="textStart"
        app:iconPadding="@dimen/space_s"
        app:iconTint="@color/color_text_primary"
        app:rippleColor="@color/color_ripple" />

</LinearLayout>
