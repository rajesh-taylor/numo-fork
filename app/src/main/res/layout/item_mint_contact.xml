<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:paddingVertical="@dimen/row_padding_vertical"
    android:paddingHorizontal="@dimen/margin_screen_horizontal">

    <!-- Method (label on left, matches DETAILS row labels) -->
    <TextView
        android:id="@+id/contact_method"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:text="Email"
        android:textAppearance="@style/Text.RowTitle" />

    <!-- Info (right-aligned value, matches DETAILS row values) -->
    <TextView
        android:id="@+id/contact_info"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:maxWidth="200dp"
        android:text="contact@example.com"
        android:textAppearance="@style/Text.RowSubtitle"
        android:textAlignment="textEnd"
        android:maxLines="1"
        android:ellipsize="middle" />

    <!-- Copy Button -->
    <ImageView
        android:id="@+id/copy_button"
        android:layout_width="@dimen/icon_size_small"
        android:layout_height="@dimen/icon_size_small"
        android:layout_marginStart="@dimen/space_s"
        android:padding="@dimen/space_xs"
        android:src="@drawable/ic_copy"
        app:tint="@color/color_text_tertiary"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:clickable="true"
        android:focusable="true"
        android:contentDescription="@string/mint_details_copy" />

    <!-- Hidden icon view for compatibility -->
    <ImageView
        android:importantForAccessibility="no"
        android:id="@+id/contact_icon"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:visibility="gone" />

</LinearLayout>
