<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@color/color_bg_white">

    <!-- Main Content Row -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingHorizontal="@dimen/margin_screen_horizontal"
        android:paddingVertical="@dimen/row_padding_vertical">

        <!-- Text Content -->
        <LinearLayout
            android:id="@+id/text_content"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginEnd="@dimen/space_m"
            android:orientation="vertical"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toStartOf="@id/right_content"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <!-- Item Name -->
            <TextView
                android:id="@+id/item_name"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:ellipsize="end"
                android:maxLines="1"
                android:textAppearance="@style/Text.RowTitle"
                tools:text="Classic T-Shirt" />

            <!-- Item Variation (grey, smaller) -->
            <TextView
                android:id="@+id/item_variation"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="1dp"
                android:ellipsize="end"
                android:maxLines="1"
                android:textAppearance="@style/Text.RowSubtitle"
                android:visibility="gone"
                tools:text="Medium / Navy Blue"
                tools:visibility="visible" />

            <!-- Quantity and Unit Price -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_xs"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/item_quantity"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textAppearance="@style/Text.RowSubtitle"
                    tools:text="Qty: 2" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginHorizontal="@dimen/space_xs"
                    android:text="•"
                    android:textAppearance="@style/Text.RowSubtitle" />

                <TextView
                    android:id="@+id/item_price"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textAppearance="@style/Text.RowSubtitle"
                    tools:text="$24.99 each" />

            </LinearLayout>

        </LinearLayout>

        <!-- Right Side: Total and Remove Button -->
        <LinearLayout
            android:id="@+id/right_content"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <!-- Total -->
            <TextView
                android:id="@+id/item_total"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textAppearance="@style/Text.RowTitle"
                tools:text="$49.98" />

            <!-- Remove Button -->
            <ImageButton
                android:id="@+id/remove_item_button"
                android:layout_width="@dimen/icon_size_medium"
                android:layout_height="@dimen/icon_size_medium"
                android:layout_marginStart="@dimen/space_s"
                android:padding="@dimen/space_m"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="@string/desc_remove_item"
                android:src="@drawable/ic_close"
                app:tint="@color/color_icon_tertiary" />

        </LinearLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- Divider -->
    <View
        android:id="@+id/divider"
        android:layout_width="match_parent"
        android:layout_height="0.5dp"
        android:layout_marginStart="@dimen/margin_screen_horizontal"
        android:background="@color/color_divider" />

</LinearLayout>
