<?xml version="1.0" encoding="utf-8"?>
<!--
    Dark-mode variant: bg_button_white inverts to dark-gray fill, so text
    becomes white for readable contrast.
-->
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_enabled="false" android:color="#4DFFFFFF" />
    <item android:color="@color/color_text_on_dark" />
</selector>
